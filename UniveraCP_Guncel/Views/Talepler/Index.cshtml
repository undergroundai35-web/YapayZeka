@using UniCP.Models.Talepler
@model List<Request>
@using UniCP.Services
@inject IUrlEncryptionService UrlEncryption
@{
    ViewData["Title"] = "Talepler";
    Layout = "~/Views/Shared/_LayoutMusteri.cshtml";
    string? encryptedCompanyId = null;
    if (ViewBag.SelectedCompanyId != null)
    {
        encryptedCompanyId = UrlEncryption.EncryptId((int)ViewBag.SelectedCompanyId);
    }
}

<div class="space-y-6 animate-in fade-in duration-500 pb-10">
    <!-- Header with Actions -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-white tracking-tight">Geliştirme Talepleri</h1>
            <p class="text-sm text-slate-400 font-normal">Aktif geliştirme talepleri ve proje süreçleri</p>
        </div>
        <div class="flex items-center gap-3">

             <form method="get" action="/Talepler" class="flex items-center gap-2">
                <input type="text" name="searchId" value="@ViewBag.CurrentSearchId" placeholder="Talep No Ara (TFS-321...)" 
                       class="bg-slate-800 text-slate-300 text-xs rounded-xl border border-white/10 px-3 py-2.5 w-48 focus:outline-none focus:border-indigo-500 hover:bg-slate-700 transition-colors placeholder-slate-500" />
                
                @if (ViewBag.SelectedCompanyId != null)
                {
                    <input type="hidden" name="filteredCompanyId" value="@encryptedCompanyId" />
                }
                <select name="status" onchange="this.form.submit()" class="bg-slate-800 text-slate-300 text-xs rounded-xl border border-white/10 px-3 py-2.5 focus:outline-none focus:border-indigo-500 hover:bg-slate-700 transition-colors cursor-pointer">
                    <option value="">Tüm Durumlar</option>
                    @if (ViewBag.StatusList != null)
                    {
                        @foreach (var s in ViewBag.StatusList)
                        {
                             if (ViewBag.CurrentStatus == s)
                            {
                                <option value="@s" selected>@s</option>
                            }
                            else
                            {
                                <option value="@s">@s</option>
                            }
                        }
                    }
                </select>
                <button type="submit" class="hidden"></button>
            </form>

            <a href="/Talepler/CreateRequest" class="px-5 py-2.5 bg-[#DD2F42] hover:bg-[#B93042] text-white rounded-xl shadow-lg shadow-red-900/20 transition-all font-semibold text-xs flex items-center gap-2 hover:scale-[1.02] active:scale-95">
                <i class="bi bi-plus-lg"></i>
                <span>Yeni Talep Ekle</span>
            </a>
        </div>
    </div>

    <!-- Stats Row (Quick Glance) -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
        <div class="glass-panel p-5 rounded-2xl group hover:bg-slate-800/50 transition-colors">
            <p class="text-[10px] font-normal text-slate-400 tracking-wide mb-1" style="text-transform: none;">Toplam Talep</p>
            <h3 class="text-2xl font-semibold text-white">@Model.Count</h3>
        </div>
        <div class="glass-panel p-5 rounded-2xl group hover:bg-slate-800/50 transition-colors">
            <p class="text-[10px] font-normal text-slate-400 tracking-wide mb-1" style="text-transform: none;">Geliştirme Aşamasında</p>
            <h3 class="text-2xl font-semibold text-emerald-400">@Model.Count(r => r.Status == "Geliştirme" || r.Status == "Proje Testi")</h3>
        </div>
        <div class="glass-panel p-5 rounded-2xl group hover:bg-slate-800/50 transition-colors">
            <p class="text-[10px] font-normal text-slate-400 tracking-wide mb-1" style="text-transform: none;">Onay Bekleyen</p>
            <h3 class="text-2xl font-semibold text-orange-400">@Model.Count(r => r.Status == "Bütçe Onayı" || r.Status == "Müşteri UAT" || r.Status.Contains("Bekliyor"))</h3>
        </div>
        <div class="glass-panel p-5 rounded-2xl group hover:bg-slate-800/50 transition-colors">
            <p class="text-[10px] font-normal text-slate-400 tracking-wide mb-1" style="text-transform: none;">Geliştirme Bekleyen</p>
            <h3 class="text-2xl font-semibold text-blue-400">@Model.Count(r => r.Status == "Analiz")</h3>
        </div>
    </div>

    <!-- Table Container -->
    <div class="glass-panel-static rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-800/50 border-b border-white/5 text-[10px] tracking-wide text-slate-400 font-normal" style="text-transform: none;">
                        <th class="px-6 py-5 w-32">Talep No</th>
                        <th class="px-6 py-5 min-w-[300px]">Talep Başlığı</th>
                        <th class="px-6 py-5 w-40">Süreç</th>
                        <th class="px-6 py-5 w-44">Süreç Durumu</th>
                        <th class="px-6 py-5 w-40">Sorumlu</th>
                        <th class="px-6 py-5 w-32">Tarih</th>
                        <th class="px-6 py-5 w-10"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    @foreach (var request in Model)
                    {
                        var statusColor = request.Status switch
                        {
                            "Analiz" => "bg-slate-600 text-white border-slate-500",
                            "Bütçe Onayı" => "bg-blue-600 text-white border-blue-500",
                            "Geliştirme" => "bg-orange-600 text-white border-orange-500",
                            "Proje Testi" => "bg-purple-600 text-white border-purple-500",
                            "Müşteri UAT" => "bg-pink-600 text-white border-pink-500",
                            "Canlıya Geçiş" => "bg-emerald-600 text-white border-emerald-500",
                            "Yeni Talep" => "bg-blue-600 text-white border-blue-500",
                            _ => "bg-slate-600 text-white border-slate-500"
                        };

                        var stepCount = request.Status switch {
                            "Analiz" => 1,
                            "Analiz Onayı" => 2,
                            "Bütçe Onayı" => 3,
                            "Geliştirme" => 4,
                            "Proje Testi" => 5,
                            "Müşteri UAT" => 6,
                            "Canlıya Geçiş" => 7,
                            _ => 1
                        };

                        <tr class="hover:bg-slate-800/50 transition-all duration-200 cursor-pointer group request-row" 
                            data-request-id="@request.Id">
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-2">
                                    <span class="text-[11px] text-slate-400 font-normal uppercase tracking-wider">@request.DisplayId</span>
                                    @if (request.Id.StartsWith("PORTAL"))
                                    {
                                        // Badge Removed
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex flex-col">
                                    <span class="text-sm font-normal text-slate-300 transition-colors line-clamp-1 group-hover:text-indigo-300">@request.Title</span>
                                    <div class="flex items-center gap-2 mt-1">
                                        @if (request.Comments.Any())
                                        {
                                            <span class="flex items-center gap-1 text-[10px] text-slate-500 font-normal">
                                                <i class="bi bi-chat-text"></i> @request.Comments.Count
                                            </span>
                                        }
                                        @if (request.Subtasks.Any())
                                        {
                                            <span class="flex items-center gap-1 text-[10px] text-slate-500 font-normal">
                                                <i class="bi bi-list-check"></i> @request.Subtasks.Count(s => s.Completed)/@request.Subtasks.Count
                                            </span>
                                        }
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-1">
                                    @for (int i = 1; i <= 7; i++)
                                    {
                                        <div class="w-2.5 h-1 rounded-full @(i <= stepCount ? "bg-[#DD2F42] shadow-[0_0_8px_rgba(221,47,66,0.5)]" : "bg-slate-700")"></div>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <span class="inline-flex items-center px-2.5 py-1 rounded-lg @statusColor text-[10px] font-normal tracking-wide border">
                                    @request.Status
                                </span>
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-2">
                                    <div class="w-7 h-7 rounded-full bg-gradient-to-tr from-slate-700 to-slate-800 flex items-center justify-center border border-slate-600 shadow-sm overflow-hidden">
                                        <span class="text-[10px] font-semibold text-slate-300">@(request.AssignedTo?.FirstOrDefault() ?? 'A')</span>
                                    </div>
                                    <span class="text-xs font-medium text-slate-400 truncate max-w-[120px]">@request.AssignedTo</span>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-[11px] font-normal text-slate-500 tracking-tight whitespace-nowrap">@request.Date</span>
                                    @if (request.Status == "Canlıya Geçiş" && request.SurveyScore == null) 
                                    {
                                        <button onclick="openSurveyModal(event, '@request.Id')" class="px-2 py-1 rounded bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-500 text-[9px] font-medium transition-colors border border-emerald-500/20 whitespace-nowrap">
                                            <i class="bi bi-check2-circle mr-1"></i> Teslim Aldım
                                        </button>
                                    } else if (request.SurveyScore != null)
                                    {
                                        <div class="flex items-center gap-1">
                                            <span class="px-2 py-1 rounded bg-slate-800 text-amber-500 text-[9px] font-medium border border-slate-700 cursor-default" title="Değerlendirildi">
                                               <i class="bi bi-star-fill text-[8px] mr-1"></i> @request.SurveyScore
                                            </span>
                                            @if(!string.IsNullOrEmpty(request.SurveyNote))
                                            {
                                                <i class="bi bi-chat-text-fill text-slate-600 hover:text-slate-400 transition-colors text-xs cursor-help" title="@request.SurveyNote"></i>
                                            }
                                        </div>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-5 text-right">
                                @if ((request.Status == "Analiz" || request.Status == "Yeni Talep") && request.Id.StartsWith("PORTAL"))
                                {
                                    <button onclick="deleteRequest(event, '@request.Id')" class="p-2 mr-2 rounded-lg text-slate-500 hover:text-red-500 hover:bg-red-500/10 transition-colors" title="Talebi Sil">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                                <i class="bi bi-chevron-right text-slate-600 group-hover:text-white transition-colors"></i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Survey Modal -->
<div id="surveyModal" class="hidden fixed inset-0 bg-black/80 backdrop-blur-sm z-[100000] flex items-center justify-center p-4">
    <div class="bg-slate-900 rounded-3xl border border-white/10 shadow-2xl w-full max-w-sm overflow-hidden animate-in zoom-in-95 duration-200" onclick="event.stopPropagation()">
        <div class="p-8 text-center">
            <div class="w-16 h-16 rounded-full bg-emerald-500/10 flex items-center justify-center mx-auto mb-4 border border-emerald-500/20">
                 <i class="bi bi-star-fill text-2xl text-emerald-500"></i>
            </div>
            
            <h3 class="text-xl font-semibold text-white mb-2">Süreç Değerlendirmesi</h3>
            <p class="text-sm text-slate-400 mb-6">Süreç boyunca deneyimlerinizi değerlendirin</p>
            
            <div class="flex justify-center gap-2 mb-8" id="surveyStars">
                <button onclick="setSurveyScore(1)" class="survey-star text-2xl text-slate-700 hover:text-amber-500 transition-colors" data-value="1"><i class="bi bi-star-fill"></i></button>
                <button onclick="setSurveyScore(2)" class="survey-star text-2xl text-slate-700 hover:text-amber-500 transition-colors" data-value="2"><i class="bi bi-star-fill"></i></button>
                <button onclick="setSurveyScore(3)" class="survey-star text-2xl text-slate-700 hover:text-amber-500 transition-colors" data-value="3"><i class="bi bi-star-fill"></i></button>
                <button onclick="setSurveyScore(4)" class="survey-star text-2xl text-slate-700 hover:text-amber-500 transition-colors" data-value="4"><i class="bi bi-star-fill"></i></button>
                <button onclick="setSurveyScore(5)" class="survey-star text-2xl text-slate-700 hover:text-amber-500 transition-colors" data-value="5"><i class="bi bi-star-fill"></i></button>
            </div>

            <div class="mb-6">
                <textarea id="surveyNote" rows="3" class="w-full bg-slate-800/50 border border-slate-700 rounded-xl p-3 text-xs text-slate-300 placeholder:text-slate-600 focus:outline-none focus:border-emerald-500/50 focus:bg-slate-800 transition-all resize-none" placeholder="Süreçle ilgili eklemek istediğiniz notlar..."></textarea>
            </div>
            
            <div class="flex gap-3">
                <button onclick="closeSurveyModal()" class="flex-1 py-3 text-sm font-medium text-slate-400 hover:text-white transition-colors bg-slate-800 rounded-xl">Vazgeç</button>
                <button onclick="submitSurvey()" id="btnSubmitSurvey" disabled class="flex-1 py-3 bg-emerald-600 hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed text-white text-sm font-medium rounded-xl transition-all shadow-lg shadow-emerald-900/20 active:scale-95">
                    Kaydet
                </button>
            </div>
        </div>
    </div>
</div>

<partial name="Partials/_ModernRequestModal" model="new Request()" />

<script>
    @{
        var jsonOptions = new System.Text.Json.JsonSerializerOptions
        {
            PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase,
            Encoder = System.Text.Encodings.Web.JavaScriptEncoder.UnsafeRelaxedJsonEscaping
        };
        string serializedModel = System.Text.Json.JsonSerializer.Serialize(Model ?? new List<Request>(), jsonOptions);
    }
    const pageRequests = @Html.Raw(serializedModel);

    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.request-row').forEach(row => {
            row.addEventListener('click', function() {
                const id = this.getAttribute('data-request-id');
                // Handle casing differences if any
                const request = pageRequests.find(r => (r.id === id || r.Id === id));
                
                if (request) {
                    if (typeof openModernModal === 'function') {
                        openModernModal(request);
                    } else {
                        console.error('openModernModal function is not defined');
                    }
                } else {
                    console.error('Request not found for id:', id);
                }
            });
        });
    });

    // Survey Logic
    let currentSurveyRequestId = null;
    let currentSurveyScore = 0;

    function openSurveyModal(event, requestId) {
        event.stopPropagation();
        currentSurveyRequestId = requestId;
        currentSurveyScore = 0;
        
        // Reset Stars
        document.querySelectorAll('.survey-star').forEach(s => {
            s.classList.remove('text-amber-500');
            s.classList.add('text-slate-700');
        });
        document.getElementById('surveyNote').value = '';
        document.getElementById('btnSubmitSurvey').disabled = true;

        document.getElementById('surveyModal').classList.remove('hidden');
    }

    function closeSurveyModal() {
        document.getElementById('surveyModal').classList.add('hidden');
    }

    function setSurveyScore(score) {
        currentSurveyScore = score;
        document.querySelectorAll('.survey-star').forEach(s => {
            const val = parseInt(s.getAttribute('data-value'));
            if (val <= score) {
                s.classList.add('text-amber-500');
                s.classList.remove('text-slate-700');
            } else {
                s.classList.remove('text-amber-500');
                s.classList.add('text-slate-700');
            }
        });
        document.getElementById('btnSubmitSurvey').disabled = false;
    }

    function submitSurvey() {
        if (!currentSurveyRequestId || currentSurveyScore === 0) return;

        const btn = document.getElementById('btnSubmitSurvey');
        const originalText = btn.innerText;
        btn.innerText = '• • •';
        btn.disabled = true;

        const note = document.getElementById('surveyNote').value;

        fetch('/Talepler/SubmitSurvey', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${encodeURIComponent(currentSurveyRequestId)}&score=${currentSurveyScore}&note=${encodeURIComponent(note)}`
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                closeSurveyModal();
                // Optionally hide the button on the row or show success
                window.location.reload(); 
            } else {
                alert('Hata: ' + data.message);
                btn.innerText = originalText;
                btn.disabled = false;
            }
        })
        .catch(err => {
            console.error(err);
            alert('Bir hata oluştu.');
            btn.innerText = originalText;
            btn.disabled = false;
        });
    }

    function deleteRequest(event, id) {
        event.stopPropagation(); // Prevent row click
        
        if (!confirm('Bu talebi silmek istediğinize emin misiniz? Bu işlem geri alınamaz.')) return;

        fetch('/Talepler/Delete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${encodeURIComponent(id)}`
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                // Remove row with animation
                const row = event.target.closest('tr');
                if (row) {
                    row.style.transition = 'all 0.5s';
                    row.style.opacity = '0';
                    row.style.transform = 'translateX(20px)';
                    setTimeout(() => row.remove(), 500);
                } else {
                    window.location.reload();
                }
            } else {
                alert('Hata: ' + data.message);
            }
        })
        .catch(err => {
            console.error(err);
            alert('Bir hata oluştu.');
        });
    }
</script>
<style>
    .request-row {
        cursor: pointer;
    }
    .line-clamp-1 {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
</style>
