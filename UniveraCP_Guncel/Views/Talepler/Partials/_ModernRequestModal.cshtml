                <button id="btnSubmitRevision" onclick="submitRevision()" class="px-6 py-2 bg-amber-600 hover:bg-amber-700 text-white text-xs font-medium rounded-xl transition-all shadow-lg shadow-amber-900/20 active:scale-95">
                    Revize Gönder
                </button>
            </div>
        </div>
