    <!-- Revision Note Modal (Inner) -->
    <div id="revisionModal" class="hidden absolute inset-0 bg-black/60 backdrop-blur-sm z-[100000] flex items-center justify-center p-4" 
         onmousedown="onRevisionBackdropMouseDown(event)" 
         onclick="onRevisionBackdropClick(event)">
        <div class="bg-slate-900 rounded-3xl border border-white/10 shadow-2xl w-full max-w-lg overflow-hidden animate-in zoom-in-95 duration-200" onclick="event.stopPropagation()">
            <div class="px-6 py-4 border-b border-white/5 flex items-center justify-between bg-slate-800/50">
