@model List<UniCP.Controllers.ZabbixHostViewModel>
@{
    ViewData["Title"] = "Sistem Performansı";
    Layout = "_LayoutMusteri";
}

<div class="space-y-6">
    <!-- Header -->
    <div>
        <h1 class="text-3xl font-bold text-white tracking-tight">Sistem Performansı</h1>
        <p class="text-slate-400 mt-2">Gerçek zamanlı sunucu ve uygulama metrikleri</p>
    </div>
    
    <!-- Company Filter -->


    <!-- Filter Buttons -->
    <div class="flex space-x-2 mb-4">
        <a href="@Url.Action("Index", new { range = "1h", filteredCompanyId = ViewBag.SelectedCompanyId })" 
           class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(ViewBag.ActiveRange == "1h" ? "bg-emerald-500/20 text-emerald-400 border border-emerald-500/30" : "bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-white")">
            1 Saat
        </a>
        <a href="@Url.Action("Index", new { range = "24h", filteredCompanyId = ViewBag.SelectedCompanyId })" 
           class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(ViewBag.ActiveRange == "24h" || ViewBag.ActiveRange == "1d" ? "bg-emerald-500/20 text-emerald-400 border border-emerald-500/30" : "bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-white")">
            24 Saat
        </a>
        <a href="@Url.Action("Index", new { range = "7d", filteredCompanyId = ViewBag.SelectedCompanyId })" 
           class="px-4 py-2 rounded-lg text-sm font-medium transition-colors @(ViewBag.ActiveRange == "7d" || ViewBag.ActiveRange == "1w" ? "bg-emerald-500/20 text-emerald-400 border border-emerald-500/30" : "bg-slate-800 text-slate-400 hover:bg-slate-700 hover:text-white")">
            1 Hafta
        </a>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="bg-rose-500/10 text-rose-400 p-4 rounded-xl border border-rose-500/20">
            <i class="bi bi-exclamation-triangle-fill mr-2"></i> @ViewBag.Error
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        @if(ViewBag.Error == null) {
             <div class="text-slate-400 p-4 border border-slate-700 rounded-xl">İzlenen sistem bulunamadı.</div>
        }
    }
    else 
    {
        @foreach (var host in Model)
        {
            <div class="glass-panel p-6 rounded-2xl mb-8">
                <h2 class="text-2xl font-bold text-emerald-400 mb-6 flex items-center gap-2 border-b border-slate-700/50 pb-4">
                    <i class="bi bi-server"></i> @host.HostName
                </h2>

                <!-- KPI Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-4 mb-8">
                    <!-- CPU -->
                    <div class="glass-panel bg-slate-800/50 p-5 rounded-2xl flex items-center gap-4 border border-slate-700">
                        <div class="w-12 h-12 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500">
                            <i class="bi bi-cpu text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-sm text-slate-400">CPU</p>
                            <h3 class="text-xl font-bold text-white">
                                @((ViewBag.ActiveRange?.ToString() == "1h" && host.CpuHistory.Any()) 
                                    ? host.CpuHistory.Max(x => x.Value).ToString("F1") 
                                    : host.CurrentCpu.ToString("F1"))%
                            </h3>
                        </div>
                    </div>

                    <!-- RAM -->
                    <div class="glass-panel bg-slate-800/50 p-5 rounded-2xl flex items-center gap-4 border border-slate-700">
                        <div class="w-12 h-12 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500">
                            <i class="bi bi-memory text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-sm text-slate-400">RAM</p>
                            <h3 class="text-xl font-bold text-white">@host.CurrentRam.ToString("F1")%</h3>
                        </div>
                    </div>

                    <!-- Disk Usage -->
                    <div class="glass-panel bg-slate-800/50 p-5 rounded-2xl flex items-center gap-4 border border-slate-700">
                        <div class="w-12 h-12 rounded-xl bg-rose-500/10 flex items-center justify-center text-rose-500">
                            <i class="bi bi-hdd-fill text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-sm text-slate-400">Disk Doluluk</p>
                            <h3 class="text-xl font-bold text-white">@host.DiskUsagePercent.ToString("F1")%</h3>
                        </div>
                    </div>
                    
                    <!-- Disk Total -->
                    <div class="glass-panel bg-slate-800/50 p-5 rounded-2xl flex items-center gap-4 border border-slate-700">
                        <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-500">
                            <i class="bi bi-device-hdd text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-sm text-slate-400">Toplam Disk</p>
                            <h3 class="text-xl font-bold text-white">@((host.DiskTotalBytes / (1024 * 1024 * 1024)).ToString("F0")) GB</h3>
                        </div>
                    </div>

                    <!-- Disk Latency -->
                    <div class="glass-panel bg-slate-800/50 p-5 rounded-2xl flex items-center gap-4 border border-slate-700">
                        <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center text-purple-500">
                            <i class="bi bi-clock-history text-2xl"></i>
                        </div>
                        <div>
                            <p class="text-sm text-slate-400">Disk Yanıt Süresi</p>
                            <h3 class="text-xl font-bold text-white">@host.DiskLatencyMs.ToString("F2") ms</h3>
                        </div>
                    </div>
                </div>

                <!-- Charts Grid -->
                <!-- Range Label Logic -->
                @{
                    string rangeLabel = (ViewBag.ActiveRange == "7d" || ViewBag.ActiveRange == "1w") ? "1 HAFTA" : (ViewBag.ActiveRange == "24h" || ViewBag.ActiveRange == "1d" ? "24 SAAT" : "1 SAAT");
                }

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- CPU Chart -->
                    <div class="bg-slate-900/50 p-4 rounded-xl border border-slate-700/50">
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-xs font-bold text-slate-400 uppercase">CPU Geçmişi (@rangeLabel)</span>
                        </div>
                        <div class="h-48 relative w-full">
                            <canvas id="cpuChart_@host.HostId"></canvas>
                        </div>
                    </div>

                    <!-- RAM Chart -->
                    <div class="bg-slate-900/50 p-4 rounded-xl border border-slate-700/50">
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-xs font-bold text-slate-400 uppercase">RAM Geçmişi (@rangeLabel)</span>
                        </div>
                        <div class="h-48 relative w-full">
                             <canvas id="ramChart_@host.HostId"></canvas>
                        </div>
                    </div>

                    <!-- Disk Chart -->
                    <div class="bg-slate-900/50 p-4 rounded-xl border border-slate-700/50">
                        <div class="flex justify-between items-center mb-4">
                             <span class="text-xs font-bold text-slate-400 uppercase">Disk Kullanımı</span>
                        </div>
                        <div class="h-48 relative w-full flex justify-center">
                            <canvas id="diskChart_@host.HostId" class="relative z-10"></canvas>
                            <!-- Center Text Overlay -->
                            <div class="absolute inset-0 flex flex-col items-center justify-center z-0">
                                <div class="text-center">
                                     <div class="text-[10px] uppercase text-rose-500 font-bold tracking-wider leading-none mb-1">Dolu</div>
                                     <div class="text-lg font-bold text-white leading-none mb-2">@((host.DiskTotalBytes * (host.DiskUsagePercent / 100.0) / (1024 * 1024 * 1024)).ToString("F0")) <span class="text-xs font-normal text-slate-500">GB</span></div>
                                     
                                     <div class="text-[10px] uppercase text-emerald-500 font-bold tracking-wider leading-none mb-1">Boş</div>
                                     <div class="text-lg font-bold text-white leading-none">@((host.DiskTotalBytes * ((100.0 - host.DiskUsagePercent) / 100.0) / (1024 * 1024 * 1024)).ToString("F0")) <span class="text-xs font-normal text-slate-500">GB</span></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
@if (Model != null && Model.Any())
{
<script>
    (function() {
        // Namespace for charts to allow cleanup
        window.sysPerfCharts = window.sysPerfCharts || {};

        @foreach (var host in Model)
        {
            <text>
            // --- Host: @host.HostId ---
            {
                // Cleanup existing charts for this host
                const hostId = '@host.HostId';
                const cpuKey = 'cpu_' + hostId;
                const ramKey = 'ram_' + hostId;
                const diskKey = 'disk_' + hostId;

                if (window.sysPerfCharts[cpuKey]) window.sysPerfCharts[cpuKey].destroy();
                if (window.sysPerfCharts[ramKey]) window.sysPerfCharts[ramKey].destroy();
                if (window.sysPerfCharts[diskKey]) window.sysPerfCharts[diskKey].destroy();

                // Data Prep
                const cpuData = @Html.Raw(Json.Serialize(host.CpuHistory.Select(x => x.Value)));
                const ramData = @Html.Raw(Json.Serialize(host.RamHistory.Select(x => x.Value)));
                
                // Format Labels based on Range
                const range = '@ViewBag.ActiveRange';
                // Server-side formatted or JS formatted?
                // Let's rely on server side formatting or JS date parsing
                
                const rawDates = @Html.Raw(Json.Serialize(host.CpuHistory.Select(x => x.Time)));
                const labels = rawDates.map(d => {
                    const date = new Date(d);
                    if (range == '7d' || range == '1w') {
                         // Day Month Hour:Minute
                         return date.toLocaleDateString('tr-TR', { day: '2-digit', month: '2-digit' }) + ' ' + date.toLocaleTimeString('tr-TR', { hour: '2-digit', minute:'2-digit' });
                    }
                    else {
                        return date.toLocaleTimeString('tr-TR', { hour: '2-digit', minute:'2-digit' });
                    }
                });

                // CPU Chart
                const ctxCpu = document.getElementById('cpuChart_' + hostId);
                if (ctxCpu) {
                    window.sysPerfCharts[cpuKey] = new Chart(ctxCpu, {
                        type: 'line',
                        data: {
                            labels: labels,
                            datasets: [{
                                label: 'CPU %',
                                data: cpuData,
                                borderColor: '#10b981', // Emerald 500
                                backgroundColor: 'rgba(16, 185, 129, 0.1)',
                                borderWidth: 2,
                                tension: 0.4,
                                fill: true,
                                pointRadius: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                x: { display: false },
                                y: { 
                                    beginAtZero: true, 
                                    max: 100,
                                    grid: { color: 'rgba(255,255,255,0.05)' }
                                }
                            }
                        }
                    });
                }

                // RAM Chart
                const ctxRam = document.getElementById('ramChart_' + hostId);
                if (ctxRam) {
                    window.sysPerfCharts[ramKey] = new Chart(ctxRam, {
                        type: 'line',
                        data: {
                            labels: labels, // Assuming sync data
                            datasets: [{
                                label: 'RAM %',
                                data: ramData,
                                borderColor: '#f59e0b', // Amber 500
                                backgroundColor: 'rgba(245, 158, 11, 0.1)',
                                borderWidth: 2,
                                tension: 0.4,
                                fill: true,
                                pointRadius: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: { legend: { display: false } },
                            scales: {
                                x: { display: false },
                                y: { 
                                    beginAtZero: true, 
                                    max: 100, 
                                    grid: { color: 'rgba(255,255,255,0.05)' }
                                }
                            }
                        }
                    });
                }

                // Disk Chart
                const ctxDisk = document.getElementById('diskChart_' + hostId);
                if (ctxDisk) {
                    window.sysPerfCharts[diskKey] = new Chart(ctxDisk, {
                        type: 'doughnut',
                        data: {
                            labels: ['Dolu', 'Boş'],
                            datasets: [{
                                data: [@host.DiskUsagePercent.ToString(System.Globalization.CultureInfo.InvariantCulture), @((100 - host.DiskUsagePercent).ToString(System.Globalization.CultureInfo.InvariantCulture))],
                                backgroundColor: ['#f43f5e', 'rgba(255, 255, 255, 0.1)'], // Rose-500, White-10%
                                borderWidth: 0
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            cutout: '70%',
                            plugins: { legend: { display: false } }
                        }
                    });
                }
            }
            </text>
        }
    })();
</script>
}
