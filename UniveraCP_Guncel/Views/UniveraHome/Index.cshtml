@using UniCP.Models.MsK
@using UniCP.Services
@inject IUrlEncryptionService UrlEncryption
@{
    ViewData["Title"] = "Univera Anasayfa";
    var kullanici = ViewBag.Kullanici as TBL_KULLANICI;
    string? encryptedCompanyId = null;
    if (ViewBag.SelectedCompanyId != null)
    {
        encryptedCompanyId = UrlEncryption.EncryptId((int)ViewBag.SelectedCompanyId);
    }
}

<div class="space-y-8">
    <!-- Top Row: KPI Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <!-- Open Tickets -->
        <!-- Open Tickets (Volume) -->
        <div class="bg-slate-800 border border-slate-700 rounded-2xl p-6 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-red-500/10 rounded-full blur-2xl -mr-16 -mt-16 group-hover:bg-red-500/20 transition-all duration-500"></div>
            
            <div class="relative z-10 flex justify-between items-start">
                <div>
                    <p class="text-slate-400 font-medium text-sm mb-1">Aylık Destek Talebi Hacmi</p>
                    <h3 class="text-4xl font-bold text-white mb-2">@ViewBag.MonthlyVolumeCount</h3>
                    <div class="flex items-center gap-2">
                        <span class="text-slate-400 text-xs font-medium">
                            Açık Destek Talebi: @ViewBag.OpenTicketsCount
                        </span>
                    </div>
                </div>
                <div class="w-12 h-12 rounded-xl bg-slate-700/50 flex items-center justify-center border border-slate-600 group-hover:scale-110 transition-transform duration-300">
                     <i class="bi bi-life-preserver text-red-500 text-xl"></i>
                </div>
            </div>
            
            <div class="mt-4 flex items-center gap-2 text-xs text-slate-500">
                <span class="font-bold text-red-400">@ViewBag.CriticalCount Kritik</span> aksiyon bekliyor
            </div>
        </div>

        <!-- Progressing Projects -->
        <div class="glass-panel bg-slate-800 interactive-card p-6 rounded-2xl flex items-start justify-between group hover:glow-purple">
            <div>
                <p class="text-xs font-semibold text-slate-400 mb-2">Açık Geliştirme Talepleri</p>
                <h3 class="text-4xl font-bold text-white">@(ViewBag.OpenDevRequestsCount ?? 0)</h3>
                <p class="text-[11px] text-slate-400 mt-4 leading-relaxed">
                    2 proje <span class="text-emerald-400 font-bold italic">planlanan tarihte</span>
                </p>
            </div>
            <div class="p-3 bg-pink-500/10 text-pink-500 rounded-xl flex items-center justify-center border border-pink-500/20 group-hover:scale-110 transition-transform">
                <i class="bi bi-briefcase text-2xl"></i>
            </div>
        </div>

        <!-- Pending Budget -->
        <div class="glass-panel bg-slate-800 interactive-card p-6 rounded-2xl flex items-start justify-between group hover:glow-amber">
            <div>
                <p class="text-xs font-semibold text-slate-400 mb-2">Bekleyen Talep Eforu</p>
                @{
                    decimal effort = ViewBag.PendingBudgetEffort ?? 0;
                    decimal cost = effort * 22500;
                }
                <h3 class="text-4xl font-bold text-emerald-400">₺@cost.ToKMB()</h3>
                
                <div class="mt-4 flex items-center space-x-2">
                    <span class="text-sm font-bold text-white">@effort.ToString("N1")</span>
                    <span class="text-[10px] font-bold text-slate-500">A/G lik efor maliyetidir</span>
                </div>
            </div>
            <div class="p-3 bg-orange-500/10 text-orange-500 rounded-xl flex items-center justify-center border border-orange-500/20 group-hover:scale-110 transition-transform">
                <i class="bi bi-check-circle text-2xl"></i>
            </div>
        </div>

        <!-- Pending Budget Cost (Replaces Support SLA) -->
        <div class="glass-panel bg-slate-800 interactive-card p-6 rounded-2xl flex items-start justify-between group hover:glow-emerald">
            <div>
                <p class="text-xs font-semibold text-slate-400 mb-2">Onay Bekleyen Bütçe</p>
                <h3 class="text-4xl font-bold text-white">₺@(((decimal)(ViewBag.PendingBudgetCost ?? 0)).ToKMB())</h3>
                <p class="text-[11px] text-slate-400 mt-4 leading-relaxed">
                    Onay bekleyen toplam <span class="text-emerald-400 font-bold">fatura tutarı</span>
                </p>
            </div>
            <div class="p-3 bg-emerald-500/10 text-emerald-500 rounded-xl flex items-center justify-center border border-emerald-500/20 group-hover:scale-110 transition-transform">
                <i class="bi bi-currency-exchange text-2xl"></i>
            </div>
        </div>
    </div>

    <!-- Main Content Area: Charts & Action Items -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <!-- SLA Charts (8 cols) -->
        <!-- Financial Overview Chart (8 cols) -->
        <!-- Financial Overview Chart (8 cols) -->
        <!-- SLA Charts (8 cols) -->
        <!-- SLA Charts (8 cols) -->
        <!-- New Charts Section (8 cols) -->
        <div class="lg:col-span-8 glass-panel p-8 rounded-[2rem] overflow-hidden">
            <h2 class="text-lg font-semibold text-white tracking-tight mb-8">Performans ve Finans</h2>

            <div class="grid grid-cols-1 gap-8">
                <!-- 1. Monthly Invoiced Orders (Bar) - MOVED TO TOP & FULL WIDTH -->
                <div class="relative flex flex-col items-center group w-full">
                    <p class="text-xs font-bold text-slate-400 mb-2 text-center">Son 6 Aylık Ciro ve Açık Siparişler</p>
                    @if (!string.IsNullOrEmpty(ViewBag.AuthorizedCompanyNames as string)) {
                        <p class="text-[10px] text-slate-500 mb-2 text-center truncate max-w-[200px]" title="@ViewBag.AuthorizedCompanyNames">
                            <i class="bi bi-building mr-1"></i>@ViewBag.AuthorizedCompanyNames
                        </p>
                    }
                    <div class="h-[240px] w-full relative flex justify-center items-center">
                        <canvas id="financeOrdersChart"></canvas>
                         <div id="financeNoData" class="absolute inset-0 flex items-center justify-center flex-col pointer-events-none hidden">
                            <i class="bi bi-bar-chart text-slate-700 text-4xl mb-2"></i>
                             <span class="text-xs text-slate-500 font-medium">Veri Bulunamadı</span>
                        </div>
                    </div>
                     <!-- Debug Info -->
                     @{ var fData = ViewBag.FinanceChartData as IEnumerable<dynamic>; }
                    <div class="absolute bottom-0 right-0 opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 p-1 rounded text-[9px] text-slate-300">
                        Rows: @(fData?.Count() ?? 0)
                    </div>
                </div>

                <!-- 2. Split Row: Budget Requests & Support Requests -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 w-full">
                    
                    <!-- LEFT: Dev Requests Ratio (Doughnut) -->
                    <div class="relative flex flex-col items-center group w-full">
                        <p class="text-xs font-bold text-slate-400 mb-4 text-center">Bütçe Onayı Bekleyen Geliştirme Talepleri</p>
                        <div class="h-[240px] w-full relative flex justify-center items-center">
                            <canvas id="devRequestsChart"></canvas>
                            <div id="devRequestsNoData" class="absolute inset-0 flex items-center justify-center flex-col pointer-events-none hidden">
                                <i class="bi bi-pie-chart text-slate-700 text-4xl mb-2"></i>
                                <span class="text-xs text-slate-500 font-medium">Veri Bulunamadı</span>
                            </div>
                        </div>
                        <!-- Debug Info -->
                        <div class="absolute bottom-0 right-0 opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 p-1 rounded text-[9px] text-slate-300">
                            O: @(ViewBag.OpenDevRequestsCount ?? 0) | C: @(ViewBag.CompletedDevRequestsCount ?? 0)
                        </div>
                    </div>

                    <!-- RIGHT: Open Support Requests (Horizontal Bar) - NEW -->
                    <div class="relative flex flex-col items-center group w-full">
                        <p class="text-xs font-bold text-slate-400 mb-4 text-center">Açık Destek Talepleri (Bu Ay)</p>
                        <div class="h-[240px] w-full relative flex justify-center items-center">
                            <canvas id="supportRequestsChart"></canvas>
                            <div id="supportRequestsNoData" class="absolute inset-0 flex items-center justify-center flex-col pointer-events-none hidden">
                                <i class="bi bi-life-preserver text-slate-700 text-4xl mb-2"></i>
                                <span class="text-xs text-slate-500 font-medium">Veri Bulunamadı (Bu Ay)</span>
                            </div>
                        </div>
                        <div class="absolute bottom-0 right-0 opacity-0 group-hover:opacity-100 transition-opacity bg-black/50 p-1 rounded text-[9px] text-slate-300">
                             Total: @(ViewBag.OpenTicketsCount ?? 0)
                        </div>
                        
                    </div>

                </div>
            </div>
            </div>
            
        <!-- Action Waiting (4 cols) -->
        <div class="lg:col-span-4 glass-panel p-8 rounded-[2rem] h-full flex flex-col">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center space-x-3">
                    <h2 class="text-lg font-semibold text-white tracking-tight">Aksiyon Bekleyenler</h2>
                    <span class="px-2.5 py-0.5 bg-slate-700/50 text-slate-300 text-[10px] font-bold rounded-full border border-slate-600/30">4</span>
                </div>
            </div>
            
            <div class="space-y-3 flex-1 overflow-y-auto pr-2 custom-scrollbar">
                <!-- Action Case 1 -->
                <!-- Action Case 1 -->
                <a href="@Url.Action("Index", "Finans", new { filteredCompanyId = encryptedCompanyId })" class="relative p-4 rounded-xl bg-slate-800/40 border border-slate-700/50 hover:bg-slate-800/80 transition-all duration-300 group cursor-pointer hover:border-red-500/30 block">
                    <div class="flex items-center space-x-4">
                        <div class="p-3 bg-red-500/10 text-red-500 rounded-xl group-hover:scale-110 transition-transform duration-300 border border-red-500/20">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="text-sm font-medium text-slate-200 mb-0.5 group-hover:text-white transition-colors">Fatura Onayı Gerekli</h4>
                            <p class="text-[11px] text-slate-400 font-medium"><span class="text-red-400 font-bold">@ViewBag.FinancePendingCount</span> adet sipariş fatura onayı bekliyor.</p>
                        </div>
                        <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                            <i class="bi bi-chevron-right text-slate-500 text-xs"></i>
                        </div>
                    </div>
                </a>

                <!-- Action Case 2 -->
                <!-- Action Case 2 -->
                <a href="@Url.Action("Index", "Lisanslar", new { filteredCompanyId = encryptedCompanyId })" class="relative p-4 rounded-xl bg-slate-800/40 border border-slate-700/50 hover:bg-slate-800/80 transition-all duration-300 group cursor-pointer hover:border-amber-500/30 block">
                    <div class="flex items-center space-x-4">
                        <div class="p-3 bg-amber-500/10 text-amber-500 rounded-xl group-hover:scale-110 transition-transform duration-300 border border-amber-500/20">
                            <i class="bi bi-file-text-fill"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="text-sm font-medium text-slate-200 mb-0.5 group-hover:text-white transition-colors">Sözleşme Yenileme</h4>
                            <p class="text-[11px] text-slate-400 font-medium"><span class="text-amber-400 font-bold">@ViewBag.ExpiredLicenseCount</span> adet lisansın yenileme tarihi geçti.</p>
                        </div>
                         <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                            <i class="bi bi-chevron-right text-slate-500 text-xs"></i>
                        </div>
                    </div>
                </a>

                <!-- Action Case 3 -->
                <!-- Action Case 3 -->
                <a href="@Url.Action("Index", "Talepler", new { status = "Müşteri UAT", filteredCompanyId = encryptedCompanyId })" class="relative p-4 rounded-xl bg-slate-800/40 border border-slate-700/50 hover:bg-slate-800/80 transition-all duration-300 group cursor-pointer hover:border-blue-500/30 block">
                    <div class="flex items-center space-x-4">
                        <div class="p-3 bg-blue-500/10 text-blue-500 rounded-xl group-hover:scale-110 transition-transform duration-300 border border-blue-500/20">
                            <i class="bi bi-play-circle-fill"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="text-sm font-medium text-slate-200 mb-0.5 group-hover:text-white transition-colors">UAT Test Bekliyor</h4>
                            <p class="text-[11px] text-slate-400 font-medium"><span class="text-blue-400 font-bold">@ViewBag.UatTestCount</span> adet geliştirme talebi test onayınızı bekliyor.</p>
                        </div>
                         <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                            <i class="bi bi-chevron-right text-slate-500 text-xs"></i>
                        </div>
                    </div>
                </a>

                 <!-- Action Case 4 -->
                <div class="relative p-4 rounded-xl bg-slate-800/40 border border-slate-700/50 hover:bg-slate-800/80 transition-all duration-300 group cursor-pointer hover:border-purple-500/30">
                    <div class="flex items-center space-x-4">
                        <div class="p-3 bg-purple-500/10 text-purple-500 rounded-xl group-hover:scale-110 transition-transform duration-300 border border-purple-500/20">
                            <i class="bi bi-chat-text-fill"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <h4 class="text-sm font-medium text-slate-200 mb-0.5 group-hover:text-white transition-colors">Memnuniyet Anketi</h4>
                            <p class="text-[11px] text-slate-400 font-medium">Kapanan REQ-099 talebi için anketinizi tamamlayın.</p>
                        </div>
                         <div class="opacity-0 group-hover:opacity-100 transition-opacity">
                            <i class="bi bi-chevron-right text-slate-500 text-xs"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Custom Plugin for Line Shadow
        const lineShadowPlugin = {
            id: 'lineShadow',
            beforeDatasetsDraw: (chart) => {
                if (chart.config.type !== 'line') return;
                const ctx = chart.ctx;
                chart.data.datasets.forEach((dataset, i) => {
                    const meta = chart.getDatasetMeta(i);
                    if (meta.hidden) return;
                    ctx.save();
                    ctx.shadowColor = dataset.borderColor;
                    ctx.shadowBlur = 10;
                    ctx.shadowOffsetY = 10;
                    meta.dataset.draw(ctx);
                    ctx.restore();
                });
            }
        };
        Chart.register(lineShadowPlugin);

        // Common Chart Defaults
        Chart.defaults.font.family = "'Inter', sans-serif";
        Chart.defaults.font.weight = '600';
        Chart.defaults.color = '#64748b'; // Slate-500 for chart labels

        // 1. Budget Approval Requests Chart (New: Horizontal Bar)
        const budgetStats = @Html.Raw(Json.Serialize(ViewBag.BudgetApprovalStats));
        
        if (!budgetStats || budgetStats.length === 0) {
            document.getElementById('devRequestsNoData').classList.remove('hidden');
            document.getElementById('devRequestsChart').style.opacity = '0.3';
             
             // Render empty placeholder
             if (window.devRequestsChartInstance) window.devRequestsChartInstance.destroy();
             
             window.devRequestsChartInstance = new Chart(document.getElementById('devRequestsChart'), {
                 type: 'bar',
                 data: { labels: ['Veri Yok'], datasets: [{ data: [0] }] },
                 options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display:false }, y: { display:false } } }
             });
        } else {
             // Extract labels (Company Names) and Data (Cost)
             const budgetLabels = budgetStats.map(x => x.companyName);
             const budgetCosts = budgetStats.map(x => x.estimatedCost);
             const budgetCounts = budgetStats.map(x => x.count);

             // Blue/Sky/Indigo Palette
             const palette = [
                 '#3b82f6', // Blue 500
                 '#0ea5e9', // Sky 500
                 '#6366f1', // Indigo 500
                 '#06b6d4', // Cyan 500
                 '#60a5fa', // Blue 400
                 '#818cf8', // Indigo 400
                 '#22d3ee', // Cyan 400
                 '#93c5fd', // Blue 300
             ];

             // Dynamic Height Calculation
             const distinctCompanies = budgetLabels.length;
             if (distinctCompanies > 2) {
                 const newHeight = Math.max(240, distinctCompanies * 70); // 70px per company
                 document.getElementById('devRequestsChart').parentElement.style.height = newHeight + 'px';
             }

             if (window.devRequestsChartInstance) window.devRequestsChartInstance.destroy();

             window.devRequestsChartInstance = new Chart(document.getElementById('devRequestsChart'), {
                 type: 'bar',
                 data: {
                     labels: budgetLabels,
                     datasets: [{
                         label: 'Maliyet',
                         data: budgetCosts,
                         backgroundColor: (ctx) => palette[ctx.dataIndex % palette.length],
                         borderRadius: 6,
                         barPercentage: 0.5,
                         categoryPercentage: 0.6,
                         maxBarThickness: 30
                     }]
                 },
                 options: {
                     indexAxis: 'y', // Horizontal Bar
                     responsive: true,
                     maintainAspectRatio: false,
                     plugins: {
                         legend: { display: false },
                         tooltip: {
                             backgroundColor: '#1e293b',
                             titleColor: '#fff',
                             bodyColor: '#cbd5e1',
                             borderColor: '#334155',
                             borderWidth: 1,
                             padding: 10,
                             callbacks: {
                                 label: function(context) {
                                     let val = context.raw;
                                     let idx = context.dataIndex;
                                     let count = budgetCounts[idx];
                                     return `Maliyet: ₺${val.toLocaleString('tr-TR')} (${count} Talep)`;
                                 }
                             }
                         }
                     },
                     scales: {
                         x: {
                             grid: { color: 'rgba(255, 255, 255, 0.05)' },
                             ticks: { 
                                 color: '#94a3b8', 
                                 font: { size: 9 },
                                 callback: function(val) { return '₺' + (val/1000) + 'K'; } 
                             }
                         },
                         y: {
                             grid: { display: false },
                             ticks: { color: '#cbd5e1', font: { size: 10 } }
                         }
                     }
                 }
            });
        }

        // 1.b Open Support Requests Chart (New: Horizontal Bar)
        const supportStats = @Html.Raw(Json.Serialize(ViewBag.SupportRequestStats));
        
        if (!supportStats || supportStats.length === 0) {
            document.getElementById('supportRequestsNoData').classList.remove('hidden');
            document.getElementById('supportRequestsChart').style.opacity = '0.3';
             
             if (window.supportRequestsChartInstance) window.supportRequestsChartInstance.destroy();
             
             window.supportRequestsChartInstance = new Chart(document.getElementById('supportRequestsChart'), {
                 type: 'bar',
                 data: { labels: ['Veri Yok'], datasets: [{ data: [0] }] },
                 options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display:false }, y: { display:false } } }
             });
        } else {
             // Extract labels (Company Names) and Data (Count)
             const supportLabels = supportStats.map(x => x.companyName);
             const supportCounts = supportStats.map(x => x.count);

             // Blue/Sky/Indigo Palette
             const palette = [
                 '#3b82f6', '#0ea5e9', '#6366f1', '#06b6d4', '#60a5fa', '#818cf8', '#22d3ee', '#93c5fd'
             ];

             // Check Height
             const distinctCompanies = supportLabels.length;
             if (distinctCompanies > 2) {
                 const newHeight = Math.max(240, distinctCompanies * 60); 
                 document.getElementById('supportRequestsChart').parentElement.style.height = newHeight + 'px';
             }

             if (window.supportRequestsChartInstance) window.supportRequestsChartInstance.destroy();

             window.supportRequestsChartInstance = new Chart(document.getElementById('supportRequestsChart'), {
                 type: 'bar',
                 data: {
                     labels: supportLabels,
                     datasets: [{
                         label: 'Açık Talep Sayısı',
                         data: supportCounts,
                         backgroundColor: (ctx) => palette[ctx.dataIndex % palette.length],
                         borderRadius: 6,
                         barPercentage: 0.5,
                         categoryPercentage: 0.6,
                         maxBarThickness: 30
                     }]
                 },
                 options: {
                     indexAxis: 'y',
                     responsive: true,
                     maintainAspectRatio: false,
                     plugins: {
                         legend: { display: false },
                         tooltip: {
                             backgroundColor: '#1e293b',
                             titleColor: '#fff',
                             bodyColor: '#cbd5e1',
                             borderColor: '#334155',
                             borderWidth: 1,
                             callbacks: {
                                 label: function(context) {
                                     return `Açık Talep: ${context.raw}`;
                                 }
                             }
                         }
                     },
                     scales: {
                         x: {
                             grid: { color: 'rgba(255, 255, 255, 0.05)' },
                             ticks: { color: '#94a3b8', font: { size: 9 }, stepSize: 1 }
                         },
                         y: {
                             grid: { display: false },
                             ticks: { color: '#cbd5e1', font: { size: 10 } }
                         }
                     }
                 }
            });
        }

        // 2. Finance Orders Monthly Multi-Line Chart
        const financeData = @Html.Raw(Json.Serialize(ViewBag.FinanceChartData));
        const financeLabels = financeData ? financeData.map(d => d.month) : [];
        const closedValues = financeData ? financeData.map(d => d.closed) : [];
        const openValues = financeData ? financeData.map(d => d.open) : [];
        
        // Detailed Data Maps
        const closedDetails = financeData ? financeData.map(d => d.closedDetails) : [];
        const openDetails = financeData ? financeData.map(d => d.openDetails) : [];

        const totalFinance = closedValues.reduce((a, b) => a + b, 0) + openValues.reduce((a, b) => a + b, 0);

        if (!financeData || totalFinance === 0) {
             document.getElementById('financeNoData').classList.remove('hidden');
             document.getElementById('financeOrdersChart').style.opacity = '0.3';
             
             if (window.financeChartInstance) window.financeChartInstance.destroy();

             window.financeChartInstance = new Chart(document.getElementById('financeOrdersChart'), {
                type: 'line',
                data: {
                    labels: ['Oca', 'Şub', 'Mar', 'Nis', 'May', 'Haz'],
                    datasets: [{ label: 'Empty', data: [0,0,0,0,0,0] }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { display: true, beginAtZero: true, grid: { color: 'rgba(255, 255, 255, 0.05)' }, ticks: { display: false } },
                        x: { display: true, grid: { display: false }, ticks: { color: '#475569' } }
                    }
                }
            });
        } else {
             if (window.financeChartInstance) window.financeChartInstance.destroy();

             window.financeChartInstance = new Chart(document.getElementById('financeOrdersChart'), {
                type: 'line',
                data: {
                    labels: financeLabels,
                    datasets: [
                        {
                            label: 'Ciro (Kapalı)',
                            data: closedValues,
                            borderColor: '#8b5cf6', // Violet-500
                            backgroundColor: (context) => {
                                const ctx = context.chart.ctx;
                                const gradient = ctx.createLinearGradient(0, 0, 0, 240);
                                gradient.addColorStop(0, 'rgba(139, 92, 246, 0.5)');
                                gradient.addColorStop(1, 'rgba(139, 92, 246, 0)');
                                return gradient;
                            },
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            pointBackgroundColor: '#8b5cf6',
                            pointBorderColor: '#1e293b',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        },
                        {
                            label: 'Açık Sipariş',
                            data: openValues,
                            borderColor: '#f59e0b', // Amber-500
                            backgroundColor: (context) => {
                                const ctx = context.chart.ctx;
                                const gradient = ctx.createLinearGradient(0, 0, 0, 240);
                                gradient.addColorStop(0, 'rgba(245, 158, 11, 0.5)');
                                gradient.addColorStop(1, 'rgba(245, 158, 11, 0)');
                                return gradient;
                            },
                            borderWidth: 2,
                            tension: 0.4,
                            fill: true,
                            pointBackgroundColor: '#f59e0b',
                            pointBorderColor: '#1e293b',
                            pointBorderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: {
                        mode: 'nearest',
                        axis: 'x',
                        intersect: true, // Tooltip only shows when hovering over the point
                    },
                    plugins: {
                        legend: { 
                            display: true,
                            labels: { color: '#94a3b8', font: { size: 10 }, usePointStyle: true, boxWidth: 6 } 
                        },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            titleColor: '#fff',
                            bodyColor: '#cbd5e1',
                            borderColor: '#334155',
                            borderWidth: 1,
                            padding: 12,
                            boxPadding: 4,
                            usePointStyle: true,
                            callbacks: {
                                label: function(context) {
                                    let value = context.raw;
                                    return context.dataset.label + ': ₺' + value.toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: {
                                color: 'rgba(255, 255, 255, 0.05)',
                                drawBorder: false
                            },
                            ticks: {
                                font: { size: 10 },
                                color: '#64748b',
                                callback: function(value) {
                                    if (value === 0) return '₺0';
                                    if (value < 1000) return '₺' + value;
                                    return '₺' + (value / 1000).toFixed(1).replace('.0','') + 'K';
                                }
                            }
                        },
                        x: {
                            grid: { display: false },
                            ticks: {
                                font: { size: 10 },
                                color: '#64748b'
                            }
                        }
                    }
                }
            });
        }
    </script>
}
