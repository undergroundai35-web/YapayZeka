<script>
    // Payment Modal Functions
    function openPaymentModal() {
        document.getElementById('paymentModal').classList.remove('hidden');
        document.body.style.overflow = 'hidden'; // Prevent scrolling
        calculatePaymentTotal(); // Initial calc
    }

    function closePaymentModal() {
        document.getElementById('paymentModal').classList.add('hidden');
        document.body.style.overflow = ''; // Restore scrolling
    }

    // Close on backdrop click
    document.getElementById('paymentModal').addEventListener('click', function(e) {
        if (e.target === this) closePaymentModal();
    });

    function toggleAllPayment(source) {
        const checkboxes = document.querySelectorAll('.payment-checkbox');
        checkboxes.forEach(cb => {
            cb.checked = source.checked;
        });
        calculatePaymentTotal();
    }

    function calculatePaymentTotal() {
        let total = 0;
        const checkboxes = document.querySelectorAll('.payment-checkbox:checked');
        
        checkboxes.forEach(cb => {
            // Re-parsing logic:
            // 1. Remove thousands separator (dots)
            // 2. Replace decimal separator (comma) with dot
            
            let valStr = cb.value.replace(/\./g, '').replace(',', '.'); // Simplified parsing
            let val = parseFloat(valStr);
            if (!isNaN(val)) total += val;
        });

        const formatter = new Intl.NumberFormat('tr-TR', {
            style: 'currency',
            currency: 'TRY',
            minimumFractionDigits: 2
        });
        
        document.getElementById('paymentTotalDisplay').innerText = formatter.format(total);
    }

    // Toggle Tabs
    function switchPaymentTab(tabName) {
        // Hide all contents
        document.getElementById('tabContent_creditCard').classList.add('hidden');
        document.getElementById('tabContent_creditCard').classList.remove('flex');
        document.getElementById('tabContent_bankTransfer').classList.add('hidden');
        document.getElementById('tabContent_bankTransfer').classList.remove('flex');

        // Reset Buttons
        document.getElementById('tabBtn_creditCard').classList.remove('text-emerald-600', 'border-emerald-600');
        document.getElementById('tabBtn_creditCard').classList.add('text-slate-400', 'border-transparent');
        
        document.getElementById('tabBtn_bankTransfer').classList.remove('text-emerald-600', 'border-emerald-600');
        document.getElementById('tabBtn_bankTransfer').classList.add('text-slate-400', 'border-transparent');

        // Show Active
        const startClass = tabName === 'creditCard' ? 'justify-between' : 'h-full';
        
        const activeContent = document.getElementById('tabContent_' + tabName);
        activeContent.classList.remove('hidden');
        activeContent.classList.add('flex');

        // Style Active Button
        const activeBtn = document.getElementById('tabBtn_' + tabName);
        activeBtn.classList.remove('text-slate-400', 'border-transparent');
        activeBtn.classList.add('text-emerald-600', 'border-emerald-600');
    }

    // Validation Logic
    document.addEventListener('DOMContentLoaded', function() {
        const cardName = document.getElementById('cardName');
        const cardNumber = document.getElementById('cardNumber');
        const cardMonth = document.getElementById('cardMonth');
        const cardYear = document.getElementById('cardYear');
        const cardCvc = document.getElementById('cardCvc');

        if(cardName) {
            // Name: Max 30 handled by maxlength
        }

        if(cardNumber) {
            // Card Number: 4-4-4-4
            cardNumber.addEventListener('input', function(e) {
                let value = e.target.value.replace(/\D/g, '').substring(0, 16);
                let formatted = value.match(/.{1,4}/g)?.join('-') || value;
                if (value.length > 0 && value.length % 4 === 0 && e.inputType !== 'deleteContentBackward' && value.length < 16) {
                    // Optimized typing feel - handled by regex above mostly, but regex handles full string
                }
                e.target.value = formatted;
            });
        }

        if(cardMonth) {
            // Month: Max 12, Int
            cardMonth.addEventListener('input', function(e) {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length > 2) value = value.substring(0, 2);
                if (parseInt(value) > 12) value = '12';
                if (value === '00') value = '01'; 
                e.target.value = value;
            });
        }

        if(cardYear) {
            // Year: 00-99, Int
            cardYear.addEventListener('input', function(e) {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length > 2) value = value.substring(0, 2);
                e.target.value = value;
            });
        }

        if(cardCvc) {
             // CVC: 3 digits
            cardCvc.addEventListener('input', function(e) {
                let value = e.target.value.replace(/\D/g, '');
                if (value.length > 3) value = value.substring(0, 3);
                e.target.value = value;
            });
        }
    });

    function submitSecurePayment() {
        // Collect checked orders
        const checkboxes = document.querySelectorAll('.payment-checkbox:checked');
        if (checkboxes.length === 0) {
            alert('Lütfen ödenecek en az bir sipariş seçiniz.');
            return;
        }

        const ids = [];
        let total = 0;
        checkboxes.forEach(cb => {
            ids.push(cb.getAttribute('data-id'));
            let valStr = cb.value.replace(/\./g, '').replace(',', '.');
            let val = parseFloat(valStr);
            if (!isNaN(val)) total += val;
        });

        if (total <= 0) {
            alert('Ödenecek tutar 0 olamaz.');
            return;
        }

        // Validate form
        const agreement = document.getElementById('agreement');
        if (!agreement || !agreement.checked) {
            alert('Lütfen Mesafeli Satış Sözleşmesi ve KVKK metnini onaylayınız.');
            return;
        }

        const cardName = document.getElementById('cardName').value.trim();
        const cardNumber = document.getElementById('cardNumber').value.replace(/\s|-/g, '');
        const cardMonth = document.getElementById('cardMonth').value.trim();
        const cardYear = document.getElementById('cardYear').value.trim();
        const cardCvc = document.getElementById('cardCvc').value.trim();

        if (!cardName || !cardNumber || !cardMonth || !cardYear || !cardCvc) {
            alert('Lütfen tüm kart bilgilerini eksiksiz doldurunuz.');
            return;
        }

        if (cardNumber.length < 15) {
            alert('Geçerli bir kart numarası giriniz.');
            return;
        }

        // Setup hidden fields and submit
        document.getElementById('hiddenSiparisKodu').value = ids.join(',');
        document.getElementById('hiddenKartNo').value = cardNumber;
        document.getElementById('hiddenTutar').value = total.toFixed(2).replace('.', ',');

        document.getElementById('tabContent_creditCard').submit();
    }

</script>
