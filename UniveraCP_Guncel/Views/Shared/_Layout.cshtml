@using Microsoft.Extensions.Configuration
@using Microsoft.AspNetCore.Identity
@using UniCP.Models.Kullanici
@using UniCP.Services
@inject IConfiguration Configuration
@inject UserManager<AppUser> UserManager
@inject IUrlEncryptionService UrlEncryption

@{
    // Layout = null; // Standard Layout should not set this to null if it's the root layout
    bool aiEnabled = Configuration.GetValue<bool>("AI:Enabled");
    var appUser = await UserManager.GetUserAsync(User);
    var tokenBalance = appUser?.TokenBalance ?? 0;
    
    // Check for Custom UserType Claim (1 = Admin/Internal)
    var userTypeClaim = User.FindFirst("UserType")?.Value;
    bool isCustomAdmin = userTypeClaim == "1" || userTypeClaim == "3";
    var currentProjectName = User.FindFirst("ProjectName")?.Value ?? "Firma Seç";
}

<!DOCTYPE html>
<html lang="tr" class="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Univera Connect</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        slate: {
                            850: '#1e293b', // Custom lighter slate for cards
                            900: '#0f172a', // Main dark bg
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    }
                }
            }
        }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Bootstrap Icons (for legacy icon support) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- HTMX for SPA-like Fluidity -->
    <script src="https://unpkg.com/htmx.org@1.9.10" integrity="sha384-D1Kt99CQMDuVetoL1lrYwg5t+9QdHe7NLX/SoJYkXDFfX37iInKRy5xLSi8nO7UC" crossorigin="anonymous"></script>

    <style>
        body { 
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0a0e1a 0%, #1a1f37 50%, #0f1629 100%);
            background-attachment: fixed;
        }
        
        /* HTMX Loading Indicator */
        .htmx-indicator {
            opacity: 0;
            transition: opacity 200ms ease-in;
        }
        .htmx-request .htmx-indicator {
            opacity: 1;
        }
        .htmx-request.htmx-indicator {
            opacity: 1;
        }
        
        /* Page Load Animation */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
/* ... existing styles ... */
        [x-cloak] { display: none !important; }
    </style>
</head>
<body class="bg-[#0F172A] text-slate-200 h-screen flex overflow-hidden selection:bg-indigo-500/30 selection:text-white">

    <!-- SIDEBAR -->
    <aside class="w-64 glass-sidebar flex-shrink-0 flex flex-col h-full z-50 transition-all duration-300">
        <!-- Brand -->
        <div class="h-20 flex items-center gap-3 px-6 border-b border-slate-700/50">
            <!-- Modern Rectangular Logo -->
            <svg width="40" height="40" viewBox="0 0 100 100" class="flex-shrink-0 hover:scale-105 transition-transform duration-300">
                <defs>
                    <linearGradient id="bgGradientLayout" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1" />
                        <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" />
                    </linearGradient>
                    <linearGradient id="uGradientLayout" x1="0%" y1="0%" x2="0%" y2="100%">
                        <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
                        <stop offset="100%" style="stop-color:#cbd5e1;stop-opacity:1" />
                    </linearGradient>
                </defs>
                <rect x="15" y="20" width="70" height="60" rx="15" fill="url(#bgGradientLayout)" class="shadow-lg" />
                <path d="M 38 40 V 58 A 12 12 0 0 0 62 58 V 40" fill="none" stroke="url(#uGradientLayout)" stroke-width="8" stroke-linecap="round" />
                <circle cx="75" cy="30" r="3" fill="#60a5fa" />
            </svg>
            <span class="text-lg font-bold text-white tracking-tight">Univera Connect</span>
        </div>

        <!-- Navigation -->
        <div class="flex-1 overflow-y-auto py-6 px-3 space-y-1">
            @{
                var filterQuery = "";
                if (Context.Request.Query.ContainsKey("filteredCompanyId"))
                {
                    // Already encrypted in URL
                    filterQuery = "?filteredCompanyId=" + Context.Request.Query["filteredCompanyId"];
                }
                else if (ViewBag.SelectedCompanyId != null)
                {
                    // Encrypt the integer ID from ViewBag
                    int? val = (int?)ViewBag.SelectedCompanyId;
                    if (val.HasValue)
                    {
                        var enc = UrlEncryption.EncryptId(val.Value);
                        filterQuery = "?filteredCompanyId=" + enc;
                    }
                }
            }

            @if (User.IsInRole("Musteri") || User.IsInRole("Admin"))
            {
                <a href="/Musteri/Index@(filterQuery)" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Musteri" ? "bg-red-500/10 text-red-500 hover:bg-red-500/20 hover:text-red-400" : "")">
                    <i class="bi bi-grid-1x2-fill mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Musteri" ? "text-red-500 group-hover:text-red-400" : "")"></i>
                    Anasayfa
                </a>
            }

            @if (User.IsInRole("UniveraHome") || User.IsInRole("Admin"))
            {
                 <a href="/UniveraHome/Index@(filterQuery)" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "UniveraHome" ? "bg-indigo-500/10 text-indigo-500 hover:bg-indigo-500/20 hover:text-indigo-400" : "")">
                     <i class="bi bi-building-fill mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "UniveraHome" ? "text-indigo-500 group-hover:text-indigo-400" : "")"></i>
                     Anasayfa (Univera)
                </a>
            }

            @if (User.IsInRole("Talepler") || User.IsInRole("Admin"))
            {
                <a href="/Talepler/Index@(filterQuery)" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Talepler" ? "bg-red-500/10 text-red-500 hover:bg-red-500/20 hover:text-red-400" : "")">
                    <i class="bi bi-kanban-fill mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Talepler" ? "text-red-500 group-hover:text-red-400" : "")"></i>
                    Geliştirme Talepleri
                </a>
            }

            <div class="h-px bg-slate-700/50 my-4 mx-3"></div>

            @if (User.IsInRole("N4B") || User.IsInRole("Admin"))
            {
                <a href="/N4B/Index@(filterQuery)" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "N4B" ? "bg-red-500/10 text-red-500 hover:bg-red-500/20 hover:text-red-400" : "")">
                    <i class="bi bi-headset mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "N4B" ? "text-red-500 group-hover:text-red-400" : "")"></i>
                    Destek Merkezi
                </a>
            }

            @if (User.IsInRole("Finans") || User.IsInRole("Admin"))
            {
                <a href="/Finans/Index@(filterQuery)" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Finans" ? "bg-red-500/10 text-red-500 hover:bg-red-500/20 hover:text-red-400" : "")">
                    <i class="bi bi-wallet2 mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Finans" ? "text-red-500 group-hover:text-red-400" : "")"></i>
                    Finans & Fatura
                </a>
            }

            @if (User.IsInRole("Academy") || User.IsInRole("Admin"))
            {
                <a href="/Academy/Index" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Academy" ? "bg-indigo-500/10 text-indigo-500 hover:bg-indigo-500/20 hover:text-indigo-400" : "")">
                    <i class="bi bi-mortarboard-fill mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Academy" ? "text-indigo-500 group-hover:text-indigo-400" : "")"></i>
                    Univera Akademi
                </a>
            }

            @if (User.IsInRole("SystemPerformance") || User.IsInRole("Admin"))
            {
                <a href="/SystemPerformance/Index@(filterQuery)" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "SystemPerformance" ? "bg-emerald-500/10 text-emerald-500 hover:bg-emerald-500/20 hover:text-emerald-400" : "")">
                    <i class="bi bi-activity mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "SystemPerformance" ? "text-emerald-500 group-hover:text-emerald-400" : "")"></i>
                    Sistem Performansı
                </a>
            }

            @if (User.IsInRole("Lisanslar") || User.IsInRole("Admin"))
            {
                <a href="/Lisanslar/Index@(filterQuery)" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Lisanslar" ? "bg-red-500/10 text-red-500 hover:bg-red-500/20 hover:text-red-400" : "")">
                    <i class="bi bi-key-fill mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Lisanslar" ? "text-red-500 group-hover:text-red-400" : "")"></i>
                    Lisans & Sözleşme
                </a>
            }

            @if (User.IsInRole("Raporlar") || User.IsInRole("Admin"))
            {
                <a href="/Raporlar/Index@(filterQuery)" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Raporlar" ? "bg-indigo-500/10 text-indigo-500 hover:bg-indigo-500/20 hover:text-indigo-400" : "")">
                    <i class="bi bi-bar-chart-fill mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Raporlar" ? "text-indigo-500 group-hover:text-indigo-400" : "")"></i>
                    Raporlar
                </a>
            }

            @if (User.IsInRole("User") || User.IsInRole("Role") || User.IsInRole("Admin") || isCustomAdmin)
            {
                 <div class="h-px bg-slate-700/50 my-4 mx-3"></div>
                 <div class="px-3 mb-2">
                     <p class="text-[10px] uppercase tracking-widest text-slate-500 font-semibold">Yönetim</p>
                 </div>

                 @if (User.IsInRole("User") || User.IsInRole("Admin") || isCustomAdmin)
                 {
                     <a href="/User/Index" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "bg-indigo-500/10 text-indigo-500 hover:bg-indigo-500/20 hover:text-indigo-400" : "")">
                        <i class="bi bi-people-fill mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "text-indigo-500 group-hover:text-indigo-400" : "")"></i>
                        Kullanıcılar
                    </a>
                 }

                 @if (User.IsInRole("Role") || User.IsInRole("Admin") || isCustomAdmin)
                 {
                     <a href="/Role/Index" class="nav-item group flex items-center px-3 py-2.5 text-sm font-medium rounded-xl transition-all duration-200 text-slate-400 hover:text-white hover:bg-white/5 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Role" ? "bg-indigo-500/10 text-indigo-500 hover:bg-indigo-500/20 hover:text-indigo-400" : "")">
                        <i class="bi bi-shield-lock-fill mr-3 text-lg transition-colors group-hover:text-white @(ViewContext.RouteData.Values["controller"]?.ToString() == "Role" ? "text-indigo-500 group-hover:text-indigo-400" : "")"></i>
                        Roller
                    </a>
                 }
            }
        </div>

        <!-- User Profile (Bottom) -->
        <div class="p-4 border-t border-slate-700/50 bg-slate-900/50 space-y-3">

            <!-- User Menu Popover -->
            <div id="user-menu-popover" class="hidden absolute bottom-24 left-4 w-60 bg-slate-800 border border-slate-700 rounded-xl shadow-xl overflow-hidden z-[60] animate-in slide-in-from-bottom-2 fade-in duration-200">
                    <!-- UniCore Removed -->
                <div class="p-1 items-center bg-slate-900/50">
                     <a href="/Account/LogOut" onclick="sessionStorage.removeItem('uniCore_enabled'); sessionStorage.removeItem('uniCore_chatOpen');" class="flex items-center gap-2 px-3 py-2 text-xs text-red-400 hover:text-red-300 hover:bg-red-500/10 rounded-lg transition-colors w-full">
                        <i class="bi bi-box-arrow-right"></i>
                        <span>Oturumu Kapat</span>
                    </a>
                </div>
            </div>

            <div onclick="toggleUserMenu()" class="flex items-center gap-3 p-2 rounded-xl hover:bg-slate-800/50 transition-colors cursor-pointer group relative" title="Kullanıcı Menüsü">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center text-white font-bold shadow-lg">
                    @User.Identity.Name?.Substring(0, 1).ToUpper()
                </div>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-white truncate">@User.Identity.Name</p>
                    <p class="text-xs text-slate-400 truncate">Müşteri Yöneticisi</p>
                </div>
                <i class="bi bi-three-dots-vertical text-slate-500 group-hover:text-white transition-colors"></i>
            </div>
        </div>
    </aside>

    <!-- CONTENT WRAPPER -->
    <div class="flex-1 flex flex-col min-w-0 overflow-hidden bg-[#0F172A] relative">
        <!-- Top Header (Mobile/Utility) -->
        <header class="h-20 flex items-center justify-between px-8 border-b border-slate-700/30 bg-[#0F172A]/80 backdrop-blur-md sticky top-0 z-40">
            <!-- Breadcrumb / Page Title Placeholder -->
            @if (ViewData["HidePageHeader"] == null || !(bool)ViewData["HidePageHeader"])
            {
                <div>
                    <h2 class="text-xl font-semibold text-white">@ViewData["Title"]</h2>
                    <p class="text-sm text-slate-500">Mevcut oturum: @DateTime.Now.ToString("dd MMMM yyyy")</p>
                </div>
            }

            <!-- Right Actions -->
            <div class="flex items-center gap-4">
                 <!-- Token Balance Badge -->
                <!-- Token Balance Badge Removed -->
                    <div class="relative">
                        <i class="bi bi-search absolute left-3 top-1/2 -translate-y-1/2 text-slate-500"></i>
                        <input type="text" placeholder="Ara..." class="bg-slate-800/50 border border-slate-700 text-sm rounded-xl pl-10 pr-4 py-2.5 text-white placeholder-slate-500 focus:outline-none focus:border-indigo-500/50 focus:ring-1 focus:ring-indigo-500/50 w-64 transition-all" />
                    </div>

                    @if (isCustomAdmin)
                    {
                        <button onclick="openGlobalCompanyModal()" class="flex items-center gap-2 px-3 py-2 bg-slate-800/50 border border-slate-700/50 hover:bg-slate-700/50 rounded-xl transition-all text-sm text-slate-300 hover:text-white">
                            <i class="bi bi-building text-indigo-400"></i>
                             <span class="max-w-[150px] truncate">@currentProjectName</span>
                            <i class="bi bi-chevron-down text-xs text-slate-500 ml-1"></i>
                        </button>
                    }
                
                <button class="w-10 h-10 rounded-xl bg-slate-800/50 border border-slate-700/50 flex items-center justify-center text-slate-400 hover:text-white hover:bg-slate-700/50 transition-all relative">
                    <i class="bi bi-bell"></i>
                    <span class="absolute top-2 right-2.5 w-2 h-2 rounded-full bg-red-500 border-2 border-[#0F172A]"></span>
                </button>
                
            </div>
        </header>

        <!-- Main Scrollable Area -->
        <main class="flex-1 overflow-y-auto p-8 scroll-smooth">
            @RenderBody()
        </main>
    </div>

    <!-- AI Chat Widget -->
    <!-- AI Chat Widget Removed -->

    <!-- Scripts for AI Chat -->
    <script>
        const chatWindow = document.getElementById('ai-chat-window');
        const chatMessages = document.getElementById('chat-messages');
        const chatInput = document.getElementById('chat-input');
        const sendBtn = document.getElementById('send-btn');
        const floatBtn = document.getElementById('ai-float-btn');
        const userMenu = document.getElementById('user-menu-popover');
        let isChatOpen = false;

        function toggleUserMenu() {
            if (userMenu) {
                userMenu.classList.toggle('hidden');
            }
        }

        // Close menu when clicking outside
        document.addEventListener('click', function(event) {
            const profileDiv = document.querySelector('[onclick="toggleUserMenu()"]');
            if (userMenu && !userMenu.classList.contains('hidden')) {
                if (!userMenu.contains(event.target) && !profileDiv.contains(event.target)) {
                    userMenu.classList.add('hidden');
                }
            }
        });

        // Restore State on Load
        document.addEventListener("DOMContentLoaded", function() {
           // UniCore Removed
        });
    </script>

    <!-- Bootstrap Bundle (Optional fallback for some components) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="Partials/_OrderDetailsModal" />
    <partial name="_CompanySelectionModal" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
