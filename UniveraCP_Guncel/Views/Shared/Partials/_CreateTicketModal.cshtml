<!-- Create Ticket Modal -->
<div id="createTicketModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[70] hidden flex items-center justify-center p-4" style="z-index: 70;">
    <div class="glass-panel bg-slate-800/95 rounded-[2rem] shadow-2xl border border-white/10 max-w-2xl w-full max-h-[90vh] overflow-hidden flex flex-col">
        
        <!-- Header -->
        <div class="px-6 py-4 border-b border-white/5 flex items-center justify-between shrink-0">
            <h3 class="text-lg font-semibold text-white">Yeni Destek Talebi Oluştur</h3>
            <button onclick="closeCreateTicketModal()" class="w-8 h-8 rounded-xl bg-slate-700 hover:bg-slate-600 flex items-center justify-center text-slate-300 hover:text-white transition-all">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="p-6 overflow-y-auto custom-scrollbar grow">
            <form id="createTicketForm" class="space-y-5" onsubmit="submitTicket(event)">
                
                <!-- Title -->
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Konu / Başlık</label>
                    <input type="text" id="ticketTitle" required
                           class="w-full bg-slate-900/50 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/50 transition-all placeholder:text-slate-600"
                           placeholder="Sorununuzu kısaca özetleyiniz...">
                </div>

                <!-- Category (Root Categories Only) -->
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Bildirim Tipi</label>
                    <div class="relative" id="categoryDropdownContainer">
                        <button type="button" onclick="toggleCategoryDropdown()" 
                                class="w-full bg-slate-900/50 border border-white/10 rounded-xl px-4 py-3 text-sm text-left flex items-center justify-between hover:border-white/20 transition-all group">
                            <span id="selectedCategoryText" class="text-slate-400">Bildirim Tipi Seçiniz...</span>
                            <i class="bi bi-chevron-down text-slate-500 group-hover:text-slate-300 transition-colors"></i>
                        </button>
                        
                        <!-- Dropdown Menu (Root Categories) -->
                        <div id="categoryDropdown" class="absolute top-full left-0 right-0 mt-2 bg-slate-800 border border-white/10 rounded-xl shadow-xl z-50 hidden max-h-60 overflow-y-auto custom-scrollbar">
                           <div class="p-2 space-y-1" id="categoryList">
                               <!-- Root categories will be injected by JS -->
                           </div>
                        </div>
                    </div>
                    <input type="hidden" id="selectedCategoryId" required>
                </div>

                <!-- Bildirim Tipi (Tree View Dropdown) -->
                <div class="space-y-1.5" id="ticketTypeContainer">
                    <label class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Kategori</label>
                    <div class="relative" id="bildirimTipiDropdownContainer">
                        <button type="button" onclick="toggleBildirimTipiDropdown()" id="bildirimTipiBtn" disabled
                                class="w-full bg-slate-900/50 border border-white/10 rounded-xl px-4 py-3 text-sm text-left flex items-center justify-between hover:border-white/20 transition-all group disabled:opacity-50 disabled:cursor-not-allowed">
                            <span id="selectedBildirimTipiText" class="text-slate-400">Önce bildirim tipi seçiniz...</span>
                            <i class="bi bi-chevron-down text-slate-500 group-hover:text-slate-300 transition-colors"></i>
                        </button>
                        
                        <!-- Dropdown Menu (Tree View) -->
                        <div id="bildirimTipiDropdown" class="absolute top-full left-0 right-0 mt-2 bg-slate-800 border border-white/10 rounded-xl shadow-xl z-50 hidden max-h-60 overflow-y-auto custom-scrollbar">
                           <div class="p-2 space-y-1" id="bildirimTipiList">
                               <!-- Sub-categories tree will be injected by JS -->
                           </div>
                        </div>
                    </div>
                    <input type="hidden" id="selectedBildirimTipiId">
                </div>

                <!-- Description -->
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Açıklama</label>
                    <textarea id="ticketDescription" rows="5" required
                              class="w-full bg-slate-900/50 border border-white/10 rounded-xl px-4 py-3 text-sm text-white focus:outline-none focus:border-emerald-500/50 focus:ring-1 focus:ring-emerald-500/50 transition-all placeholder:text-slate-600 resize-none"
                              placeholder="Detaylı açıklama..."></textarea>
                </div>

                <!-- File Upload -->
                <div class="space-y-1.5">
                    <label class="text-xs font-semibold text-slate-400 uppercase tracking-wider">Dosya Ekle</label>
                    <div class="relative group">
                        <input type="file" id="ticketFile" multiple class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" onchange="updateFileName(this)">
                        <div class="w-full bg-slate-900/50 border border-dashed border-white/20 rounded-xl px-4 py-8 flex flex-col items-center justify-center gap-2 group-hover:border-emerald-500/50 group-hover:bg-slate-900/80 transition-all">
                            <div class="w-10 h-10 rounded-full bg-slate-800 flex items-center justify-center group-hover:scale-110 transition-transform">
                                <i class="bi bi-cloud-upload text-slate-400 group-hover:text-emerald-400 transition-colors"></i>
                            </div>
                            <div class="text-center">
                                <p class="text-sm text-slate-300 font-medium" id="uploadText">Dosyaları buraya sürükleyin veya seçin</p>
                                <p class="text-[10px] text-slate-500 mt-1">PNG, JPG, PDF, DOCX (Max 10MB)</p>
                            </div>
                        </div>
                    </div>
                </div>

            </form>
        </div>

        <!-- Footer -->
        <div class="px-6 py-4 border-t border-white/5 bg-slate-800/50 flex justify-end gap-3 shrink-0">
            <button onclick="closeCreateTicketModal()" class="px-4 py-2 rounded-xl text-sm font-medium text-slate-400 hover:text-white hover:bg-white/5 transition-all">
                İptal
            </button>
            <button onclick="document.getElementById('createTicketForm').dispatchEvent(new Event('submit', {cancelable: true}))" 
                    class="px-6 py-2 bg-emerald-500 hover:bg-emerald-600 text-white text-sm font-medium rounded-xl shadow-lg shadow-emerald-500/20 hover:shadow-emerald-500/30 transition-all flex items-center gap-2">
                <span>Oluştur</span>
                <i class="bi bi-send-fill text-xs"></i>
            </button>
        </div>
    </div>
</div>

<script>
    // ========================
    // CATEGORY DROPDOWN (ROOT ONLY)
    // ========================
    let categoriesCache = null;

    function toggleCategoryDropdown() {
        const dropdown = document.getElementById('categoryDropdown');
        dropdown.classList.toggle('hidden');
        if (!dropdown.classList.contains('hidden')) {
            fetchCategories();
        }
    }

    async function fetchCategories() {
        const container = document.getElementById('categoryList');
        if (categoriesCache) {
            renderRootCategories(categoriesCache);
            return;
        }

        container.innerHTML = '<div class="p-4 text-center text-slate-400"><i class="bi bi-arrow-repeat animate-spin text-xl"></i></div>';

        try {
            const response = await fetch('/N4B/GetCategories');
            const result = await response.json();
            
            if (result.success) {
                categoriesCache = result.data;
                renderRootCategories(result.data);
            } else {
                console.error("Server Error:", result.message, result.stack);
                container.innerHTML = `<div class="p-2 text-center text-red-400 text-xs text-wrap">${result.message}</div>`;
            }
        } catch (error) {
            console.error("Category fetch error:", error);
            container.innerHTML = '<div class="p-2 text-center text-red-400 text-xs">Yükleme başarısız.</div>';
        }
    }

    function renderRootCategories(categories) {
        const container = document.getElementById('categoryList');
        let html = '';
        
        // Only show root categories (no sub-items, no tree)
        categories.forEach(cat => {
            const safeName = cat.categoryName ? cat.categoryName.replace(/'/g, "\\'") : "";
            html += `
                <button type="button" onclick="selectRootCategory(${cat.categoryID}, '${safeName}')" 
                        class="w-full text-left px-3 py-2 rounded-lg text-sm text-slate-300 hover:bg-white/5 hover:text-white transition-colors font-medium">
                    ${cat.categoryName}
                </button>
            `;
        });
        
        container.innerHTML = html;
    }

    function selectRootCategory(id, name) {
        document.getElementById('selectedCategoryId').value = id;
        document.getElementById('selectedCategoryText').textContent = name;
        document.getElementById('selectedCategoryText').classList.replace('text-slate-400', 'text-white');
        
        // Close category dropdown
        document.getElementById('categoryDropdown').classList.add('hidden');

        // Reset and fetch Bildirim Tipi
        resetBildirimTipi();
        fetchBildirimTipleri(id);
    }

    // ========================
    // BİLDİRİM TİPİ TREE VIEW
    // ========================
    function resetBildirimTipi() {
        document.getElementById('selectedBildirimTipiId').value = '';
        document.getElementById('selectedBildirimTipiText').textContent = 'Önce bildirim tipi seçiniz...';
        document.getElementById('selectedBildirimTipiText').className = 'text-slate-400';
        document.getElementById('bildirimTipiBtn').setAttribute('disabled', 'true');
        document.getElementById('bildirimTipiDropdown').classList.add('hidden');
        document.getElementById('bildirimTipiList').innerHTML = '';
    }

    function toggleBildirimTipiDropdown() {
        const btn = document.getElementById('bildirimTipiBtn');
        if (btn.disabled) return;
        
        const dropdown = document.getElementById('bildirimTipiDropdown');
        dropdown.classList.toggle('hidden');
    }

    async function fetchBildirimTipleri(categoryId) {
        try {
            const response = await fetch('/N4B/GetTicketTypes?categoryId=' + categoryId);
            const result = await response.json();
            
            if (result.success && result.data && result.data.length > 0) {
                renderBildirimTipiTree(result.data);
                document.getElementById('bildirimTipiBtn').removeAttribute('disabled');
                document.getElementById('selectedBildirimTipiText').textContent = 'Kategori seçiniz...';
            } else {
                document.getElementById('selectedBildirimTipiText').textContent = 'Bu bildirim tipi için kategori bulunamadı';
            }
        } catch (error) {
            console.error("Bildirim tipi fetch error:", error);
            document.getElementById('selectedBildirimTipiText').textContent = 'Hata oluştu';
        }
    }

    function renderBildirimTipiTree(categories) {
        const container = document.getElementById('bildirimTipiList');
        let html = '';
        
        categories.forEach(cat => {
            html += generateBildirimTipiHtml(cat, 0);
        });
        
        container.innerHTML = html;
    }

    function generateBildirimTipiHtml(cat, depth) {
        const hasChildren = cat.children && cat.children.length > 0;
        const safeName = cat.categoryName ? cat.categoryName.replace(/'/g, "\\'") : "";
        const paddingLeft = depth * 16; // 16px indent per level

        let html = `<div class="bildirim-tipi-item">`;
        
        if (hasChildren) {
            // Parent node - expandable
            html += `
                <button type="button" onclick="toggleBildirimTipiNode(this, ${cat.categoryID})" 
                        class="w-full text-left px-3 py-2 rounded-lg text-sm text-slate-300 hover:bg-white/5 hover:text-white transition-colors flex items-center gap-2 group"
                        style="padding-left: ${12 + paddingLeft}px">
                    <i class="bi bi-chevron-right text-[10px] text-slate-500 group-hover:text-slate-300 transition-all bildirim-chevron"></i>
                    <span class="font-medium">${cat.categoryName}</span>
                </button>
                <div class="hidden bildirim-sub-container" id="bildirim-sub-${cat.categoryID}">
                    ${cat.children.map(sub => generateBildirimTipiHtml(sub, depth + 1)).join('')}
                </div>
            `;
        } else {
            // Leaf node - selectable
            html += `
                <button type="button" onclick="selectBildirimTipi(${cat.categoryID}, '${safeName}')" 
                        class="w-full text-left px-3 py-2 rounded-lg text-sm text-slate-300 hover:bg-emerald-500/10 hover:text-emerald-400 transition-colors flex items-center gap-2"
                        style="padding-left: ${12 + paddingLeft}px">
                    <i class="bi bi-circle text-[6px] text-slate-600"></i>
                    <span>${cat.categoryName}</span>
                </button>
            `;
        }
        
        html += `</div>`;
        return html;
    }

    function toggleBildirimTipiNode(btn, categoryId) {
        const subContainer = document.getElementById('bildirim-sub-' + categoryId);
        if (!subContainer) return;
        
        const chevron = btn.querySelector('.bildirim-chevron');
        
        if (subContainer.classList.contains('hidden')) {
            subContainer.classList.remove('hidden');
            if (chevron) chevron.style.transform = 'rotate(90deg)';
        } else {
            subContainer.classList.add('hidden');
            if (chevron) chevron.style.transform = 'rotate(0deg)';
        }
    }

    function selectBildirimTipi(id, name) {
        document.getElementById('selectedBildirimTipiId').value = id;
        document.getElementById('selectedBildirimTipiText').textContent = name;
        document.getElementById('selectedBildirimTipiText').classList.replace('text-slate-400', 'text-white');
        
        // Close dropdown
        document.getElementById('bildirimTipiDropdown').classList.add('hidden');
    }

    // ========================
    // UTILS
    // ========================
    function updateFileName(input) {
        const text = document.getElementById('uploadText');
        if (input.files && input.files.length > 0) {
            text.textContent = `${input.files.length} dosya seçildi`;
            text.classList.add('text-emerald-400');
        } else {
            text.textContent = 'Dosyaları buraya sürükleyin veya seçin';
            text.classList.remove('text-emerald-400');
        }
    }

    function closeCreateTicketModal() {
        document.getElementById('createTicketModal').classList.add('hidden');
        // Reset form state
        document.getElementById('createTicketForm').reset();
        document.getElementById('selectedCategoryId').value = '';
        document.getElementById('selectedCategoryText').textContent = 'Bildirim Tipi Seçiniz...';
        document.getElementById('selectedCategoryText').className = 'text-slate-400';
        document.getElementById('categoryDropdown').classList.add('hidden');
        resetBildirimTipi();
        document.getElementById('bildirimTipiList').innerHTML = '';
        const uploadText = document.getElementById('uploadText');
        if (uploadText) { uploadText.textContent = 'Dosyaları buraya sürükleyin veya seçin'; uploadText.classList.remove('text-emerald-400'); }
    }

    function submitTicket(e) {
        e.preventDefault();
        
        const title = document.getElementById('ticketTitle').value.trim();
        const description = document.getElementById('ticketDescription').value.trim();
        const bildirimTipiId = document.getElementById('selectedCategoryId').value;
        const categoryId = document.getElementById('selectedBildirimTipiId').value;

        if (!title) { alert('Lütfen bir başlık giriniz.'); return; }
        if (!bildirimTipiId) { alert('Lütfen bildirim tipi seçiniz.'); return; }

        const submitBtn = document.querySelector('#createTicketModal .bg-emerald-500');
        const originalText = submitBtn.innerHTML;
        submitBtn.innerHTML = '<i class="bi bi-arrow-repeat animate-spin"></i> Gönderiliyor...';
        submitBtn.disabled = true;

        const fileInput = document.getElementById('ticketFile');
        const files = fileInput && fileInput.files ? Array.from(fileInput.files) : [];

        function sendRequest(filesData) {
            const body = `title=${encodeURIComponent(title)}&description=${encodeURIComponent(description)}&bildirimTipiId=${bildirimTipiId}&categoryId=${categoryId || ''}&filesJson=${encodeURIComponent(JSON.stringify(filesData))}`;
            
            fetch('/N4B/CreateTicket', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: body
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    closeCreateTicketModal();
                    alert('✅ ' + data.message);
                    window.location.reload();
                } else {
                    alert('❌ ' + data.message);
                    submitBtn.innerHTML = originalText;
                    submitBtn.disabled = false;
                }
            })
            .catch(err => {
                console.error('CreateTicket error:', err);
                alert('Bir hata oluştu.');
                submitBtn.innerHTML = originalText;
                submitBtn.disabled = false;
            });
        }

        if (files.length === 0) {
            sendRequest([]);
        } else {
            const filePromises = files.map(file => {
                return new Promise((resolve) => {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        // Remove data:...;base64, prefix
                        const base64 = e.target.result.split(',')[1] || '';
                        resolve({
                            fileName: file.name,
                            fileContent: base64,
                            fileType: file.type
                        });
                    };
                    reader.readAsDataURL(file);
                });
            });
            Promise.all(filePromises).then(filesData => sendRequest(filesData));
        }
    }
    
    // Outside click to close dropdowns
    document.addEventListener('click', function(e) {
        // Category dropdown
        const catDropdown = document.getElementById('categoryDropdown');
        const catContainer = document.getElementById('categoryDropdownContainer');
        if (catDropdown && !catDropdown.classList.contains('hidden') && catContainer && !catContainer.contains(e.target)) {
            catDropdown.classList.add('hidden');
        }

        // Bildirim Tipi dropdown
        const btDropdown = document.getElementById('bildirimTipiDropdown');
        const btContainer = document.getElementById('bildirimTipiDropdownContainer');
        if (btDropdown && !btDropdown.classList.contains('hidden') && btContainer && !btContainer.contains(e.target)) {
            btDropdown.classList.add('hidden');
        }
    });

</script>

<style>
    .bildirim-chevron {
        transition: transform 0.2s ease;
    }
</style>
