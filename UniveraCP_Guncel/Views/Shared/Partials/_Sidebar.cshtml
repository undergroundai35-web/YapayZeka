@using UniCP.Models.MsK
@using System.Security.Claims
@using UniCP.Services
@inject IUrlEncryptionService UrlEncryption
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    
    string IsActive(string controller, string action = null)
    {
        if (string.IsNullOrEmpty(action))
            return currentController == controller ? "bg-[#DD2F42] text-white shadow-lg shadow-[#DD2F42]/20" : "text-slate-400 hover:bg-slate-800/50 hover:text-white";
            
        return (currentController == controller && currentAction == action) ? "bg-[#DD2F42] text-white shadow-lg shadow-[#DD2F42]/20" : "text-slate-400 hover:bg-slate-800/50 hover:text-white";
    }
}

<div class="w-64 flex flex-col shrink-0 text-white border-r border-white/5 transition-all duration-300 animate-slide-left" style="background-color: var(--bg-sidebar);">
    <div class="p-10 flex flex-col items-center justify-center">
        <!-- SVG Dots Logo (Small) -->
        <!-- Modern Rectangular Logo -->
        <svg width="40" height="40" viewBox="0 0 100 100" class="mb-3 hover:scale-105 transition-transform duration-300">
            <!-- Background Rectangle -->
            <defs>
                <linearGradient id="bgGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1" /> <!-- Dark Blue -->
                    <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" /> <!-- Blue -->
                </linearGradient>
                <linearGradient id="uGradient" x1="0%" y1="0%" x2="0%" y2="100%">
                    <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
                    <stop offset="100%" style="stop-color:#cbd5e1;stop-opacity:1" />
                </linearGradient>
            </defs>
            <!-- Main Shape -->
            <rect x="15" y="20" width="70" height="60" rx="15" fill="url(#bgGradient)" class="shadow-lg" />
            
            <!-- U Shape -->
            <path d="M 38 40 V 58 A 12 12 0 0 0 62 58 V 40" 
                  fill="none" 
                  stroke="url(#uGradient)" 
                  stroke-width="8" 
                  stroke-linecap="round" />
            
            <!-- Tech Accent Dot -->
            <circle cx="75" cy="30" r="3" fill="#60a5fa" />
        </svg>
        <span class="text-[12px] font-light tracking-[0.4em] text-white/90 uppercase">Connect</span>
    </div>

    <!-- Navigation Menu -->
    <div class="px-4 py-2">
        <div class="text-[10px] font-normal text-slate-500 uppercase tracking-[0.2em] mb-4 px-4">
            MÜŞTERİ PANELİ
        </div>
    </div>

    <nav class="flex-1 px-3 space-y-1">
        @{
            // Priority: URL parameter > ViewBag.SelectedCompanyId
            string? encryptedFilteredCompanyId = null;
            
            if (Context.Request.Query.ContainsKey("filteredCompanyId"))
            {
                encryptedFilteredCompanyId = Context.Request.Query["filteredCompanyId"].ToString();
            }
            else if (ViewBag.SelectedCompanyId != null)
            {
                // If we have an int ID in Viewbag, encrypt it for the links
                // Note: ViewBag.SelectedCompanyId is int?
                int? val = (int?)ViewBag.SelectedCompanyId;
                if (val.HasValue)
                {
                    encryptedFilteredCompanyId = UrlEncryption.EncryptId(val.Value);
                }
            }
            
            // If still null, we might want to pass nothing or specific value? 
            // Passing null to route value removes the specific param usually.
            // The original logic for linkFilterId was for integer IDs.
            // Now we're dealing with encrypted strings, so we'll pass the encrypted string directly.
            // If no company is selected/filtered, the parameter will be null, which is fine for "All Companies".
        }

        @if (User.IsInRole("Musteri") || User.IsInRole("Admin"))
        {
            <a href="@Url.Action("Index", "UniveraHome", new { filteredCompanyId = encryptedFilteredCompanyId })" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all @IsActive("UniveraHome", "Index")">
                <i class="bi bi-grid text-lg"></i> 
                <span class="font-normal text-sm">Anasayfa</span>
            </a>
        }
        
        @if (User.IsInRole("Talepler") || User.IsInRole("Admin"))
        {
            <a href="@Url.Action("Index", "Talepler", new { filteredCompanyId = encryptedFilteredCompanyId })" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all @IsActive("Talepler")">
                <i class="bi bi-briefcase text-lg"></i> 
                <span class="font-normal text-sm">Talepler</span>
            </a>
        }

        @if (User.IsInRole("N4B") || User.IsInRole("Admin"))
        {
            <a href="@Url.Action("Index", "N4B", new { filteredCompanyId = encryptedFilteredCompanyId })" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all @IsActive("N4B")">
                <i class="bi bi-headset text-lg"></i> 
                <span class="font-normal text-sm">Destek</span>
            </a>
        }

        @if (User.IsInRole("Finans") || User.IsInRole("Admin"))
        {
            <a href="@Url.Action("Index", "Finans", new { filteredCompanyId = encryptedFilteredCompanyId })" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all @IsActive("Finans")">
                <i class="bi bi-file-earmark-text text-lg"></i> 
                <span class="font-normal text-sm">Finans</span>
            </a>
        }

        @if (User.IsInRole("Lisanslar") || User.IsInRole("Admin"))
        {
            <a href="@Url.Action("Index", "Lisanslar", new { filteredCompanyId = encryptedFilteredCompanyId })" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all @IsActive("Lisanslar")">
                <i class="bi bi-credit-card text-lg"></i> 
                <span class="font-normal text-sm">Lisanslar</span>
            </a>
        }

        @if (User.IsInRole("User") || User.IsInRole("Role") || User.IsInRole("Admin"))
        {
             <div class="h-px bg-white/10 my-2 mx-4"></div>
             <div class="text-[10px] font-normal text-slate-500 uppercase tracking-[0.2em] mb-2 px-4 mt-4">
                 YÖNETİM
             </div>

             @if (User.IsInRole("User") || User.IsInRole("Admin"))
             {
                 <a href="/User/Index" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all @IsActive("User")">
                    <i class="bi bi-people text-lg"></i> 
                    <span class="font-normal text-sm">Kullanıcılar</span>
                </a>
             }

             @if (User.IsInRole("Role") || User.IsInRole("Admin"))
             {
                 <a href="/Role/Index" class="w-full flex items-center space-x-3 px-4 py-3 rounded-xl transition-all @IsActive("Role")">
                    <i class="bi bi-shield-lock text-lg"></i> 
                    <span class="font-normal text-sm">Roller</span>
                </a>
             }
        }
    </nav>

    <!-- Sidebar Bottom Section -->
    <div class="mt-auto p-4 space-y-4">
        <!-- Live Status Pill -->
        <div class="mx-2 px-3 py-2 rounded-lg bg-emerald-950/30 border border-emerald-900/30 flex items-center space-x-3">
            <div class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </div>
            <span class="text-[10px] font-normal text-emerald-400 tracking-wide uppercase">Canlı Entegrasyon: Aktif</span>
        </div>

        <!-- Utility Buttons -->
        <div class="space-y-1">
            <button class="w-full flex items-center space-x-3 px-4 py-2 text-slate-400 hover:text-white transition-colors text-sm">
                <i class="bi bi-moon-stars"></i>
                <span>Gece Modu</span>
            </button>
            <a href="/Account/Logout" class="w-full flex items-center space-x-3 px-4 py-2 text-red-400 hover:text-red-300 transition-colors text-sm">
                <i class="bi bi-box-arrow-right"></i>
                <span class="font-normal">Çıkış Yap</span>
            </a>
        </div>

        <!-- User Profile Card -->
        <div class="p-4 rounded-2xl bg-slate-900/50 flex items-center space-x-3 border border-slate-800/50">
            <div class="w-10 h-10 rounded-xl bg-slate-800 flex items-center justify-center border border-slate-700 font-medium text-slate-300">
                @User.Identity.Name?[0].ToString().ToUpper()
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-white truncate">@User.Identity.Name</p>
                <p class="text-[10px] text-slate-500 font-normal">IT Direktörü</p>
            </div>
            <button class="text-slate-500 hover:text-white">
                <i class="bi bi-three-dots-vertical"></i>
            </button>
        </div>
    </div>
</div>
