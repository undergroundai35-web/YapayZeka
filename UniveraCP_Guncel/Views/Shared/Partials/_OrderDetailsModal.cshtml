<!-- Order Details Modal -->
<div id="orderDetailsModal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-[70] hidden flex items-center justify-center p-4" style="z-index: 70;">
    <div class="glass-panel bg-slate-800/95 rounded-[2rem] shadow-2xl border border-white/10 max-w-4xl w-full max-h-[80vh] overflow-hidden">
        <div class="px-6 py-4 border-b border-white/5 flex items-center justify-between">
            <h3 class="text-lg font-semibold text-white">Sipariş Detayları</h3>
            <button onclick="closeOrderDetails()" class="w-8 h-8 rounded-xl bg-slate-700 hover:bg-slate-600 flex items-center justify-center text-slate-300 hover:text-white transition-all">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        <div id="orderDetailsContent" class="p-6 overflow-y-auto max-h-[calc(80vh-80px)]">
            <!-- Details will be loaded here -->
        </div>
    </div>
</div>

<script>
    function viewOrderDetails(orderId) {
        // Ensure modal is cleanly reset
        const content = document.getElementById('orderDetailsContent');
        content.innerHTML = '<div class="flex justify-center p-4"><div class="animate-spin text-white"><i class="bi bi-arrow-clockwise text-2xl"></i></div></div>';
        document.getElementById('orderDetailsModal').classList.remove('hidden');

        fetch(`/Finans/GetOrderDetails?orderId=${orderId}`)
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    content.innerHTML = `
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead>
                                    <tr class="bg-slate-800/50 border-b border-white/5">
                                        <th class="px-4 py-3 text-[10px] font-black text-slate-400 uppercase">Ürün</th>
                                        <th class="px-4 py-3 text-[10px] font-black text-slate-400 uppercase">Miktar</th>
                                        <th class="px-4 py-3 text-[10px] font-black text-slate-400 uppercase">Birim Fiyat</th>
                                        <th class="px-4 py-3 text-[10px] font-black text-slate-400 uppercase">İndirim</th>
                                        <th class="px-4 py-3 text-[10px] font-black text-slate-400 uppercase">KDV</th>
                                        <th class="px-4 py-3 text-[10px] font-black text-slate-400 uppercase">Net Tutar</th>
                                        <th class="px-4 py-3 text-[10px] font-black text-slate-400 uppercase">Toplam</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-white/5">
                                    ${data.details.map(item => `
                                        <tr class="hover:bg-slate-700/30 transition-colors">
                                            <td class="px-4 py-3">
                                                <span class="text-sm text-white font-medium">${item.productName || '-'}</span>
                                            </td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <span class="text-[11px] text-slate-400">${item.quantity || 0} ${item.stockUnitType || ''}</span>
                                            </td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <span class="text-[11px] text-slate-300">${(item.unitPrice || 0).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ₺</span>
                                            </td>
                                            <td class="px-4 py-3">
                                                <span class="text-xs text-orange-400">%${item.lineDiscountRate || 0}</span>
                                            </td>
                                            <td class="px-4 py-3">
                                                <span class="text-xs text-slate-400">%${item.tax || 0}</span>
                                            </td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <span class="text-[11px] font-bold text-slate-300">${(item.total || 0).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ₺</span>
                                            </td>
                                            <td class="px-4 py-3 whitespace-nowrap">
                                                <span class="text-[11px] font-bold text-emerald-400">${(item.netLineTotalWithTax || 0).toLocaleString('tr-TR', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} ₺</span>
                                            </td>
                                        </tr>
                                    `).join('')}
                                </tbody>
                            </table>
                        </div>
                    `;
                } else {
                    content.innerHTML = `<div class="text-red-400 p-4">Hata: ${data.message}</div>`;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                content.innerHTML = `<div class="text-red-400 p-4">Bir bağlantı hatası oluştu.</div>`;
            });
    }

    function closeOrderDetails() {
        document.getElementById('orderDetailsModal').classList.add('hidden');
    }

    // Close modal on outside click
    document.addEventListener('DOMContentLoaded', () => {
        const modal = document.getElementById('orderDetailsModal');
        if (modal) {
             modal.addEventListener('click', function(e) {
                if (e.target === this) {
                    closeOrderDetails();
                }
            });
        }
    });
</script>
