<!-- Company Selection Modal Partial -->
<div id="global-company-modal" class="fixed inset-0 z-[100] flex items-center justify-center bg-slate-900/90 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300">
    <div class="bg-[#1E293B] border border-slate-700 rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden transform scale-95 transition-transform duration-300" id="global-company-modal-content">
        <!-- Header -->
        <div class="p-6 border-b border-slate-700/50 flex justify-between items-center bg-slate-800/50">
            <h3 class="text-lg font-semibold text-white">Firma Değiştir</h3>
            <button type="button" onclick="closeGlobalCompanyModal()" class="text-slate-400 hover:text-white transition-colors">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>
        
        <!-- Search -->
        <div class="p-4 border-b border-slate-700/50 bg-[#0F172A]/50">
            <div class="relative">
                <i class="bi bi-search absolute left-4 top-3.5 text-slate-500"></i>
                <input type="text" id="global-company-search" placeholder="Firma Ara..." 
                       class="w-full pl-11 pr-4 py-3 rounded-xl bg-slate-800 border border-slate-700 text-sm text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all">
            </div>
        </div>

        <!-- List -->
        <div class="max-h-[400px] overflow-y-auto p-2" id="global-company-list">
            <div class="p-4 text-center text-slate-500 text-sm hidden" id="global-modal-no-results">Sonuç bulunamadı</div>
            <div class="p-8 text-center" id="global-modal-loading">
                <div class="animate-spin inline-block w-8 h-8 border-4 border-current border-t-transparent text-indigo-500 rounded-full" role="status" aria-label="loading"></div>
            </div>
        </div>

        <!-- Footer -->
        <div class="p-4 border-t border-slate-700/50 bg-slate-800/50 flex justify-end gap-3">
            <button type="button" onclick="closeGlobalCompanyModal()" 
                    class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-700 transition-colors">
                İptal
            </button>
        </div>
    </div>
</div>

<script>
    let globalCompanies = [];
    let isGlobalModalOpen = false;

    function openGlobalCompanyModal() {
        const modal = document.getElementById('global-company-modal');
        const content = document.getElementById('global-company-modal-content');
        
        modal.classList.remove('hidden');
        requestAnimationFrame(() => {
            modal.classList.remove('opacity-0');
            content.classList.remove('scale-95');
            content.classList.add('scale-100');
            document.getElementById('global-company-search').focus();
        });

        fetchGlobalCompanies();
    }

    function closeGlobalCompanyModal() {
        const modal = document.getElementById('global-company-modal');
        const content = document.getElementById('global-company-modal-content');

        modal.classList.add('opacity-0');
        content.classList.remove('scale-100');
        content.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
        }, 300);
    }

    async function fetchGlobalCompanies() {
        const listContainer = document.getElementById('global-company-list');
        const loading = document.getElementById('global-modal-loading');
        
        // Use cached if available
        if (globalCompanies.length > 0) {
            loading.classList.add('hidden');
            renderGlobalCompanies(globalCompanies);
            return;
        }

        try {
            const response = await fetch('/Account/GetAdminProjects', { method: 'POST' });
            const result = await response.json();

            if (result.success) {
                globalCompanies = result.projects;
                renderGlobalCompanies(globalCompanies);
            } else {
                listContainer.innerHTML = `<div class="p-4 text-red-400 text-center text-sm">${result.message}</div>`;
            }
        } catch (error) {
            listContainer.innerHTML = `<div class="p-4 text-red-400 text-center text-sm">Bağlantı hatası</div>`;
        } finally {
            loading.classList.add('hidden');
        }
    }

    function renderGlobalCompanies(list) {
        const container = document.getElementById('global-company-list');
        const noResults = document.getElementById('global-modal-no-results');
        
        // Keep special elements
        const specialElements = Array.from(container.children).filter(c => c.id === 'global-modal-no-results' || c.id === 'global-modal-loading');
        container.innerHTML = '';
        specialElements.forEach(el => container.appendChild(el));

        if (list.length === 0) {
            noResults.classList.remove('hidden');
            return;
        }
        noResults.classList.add('hidden');

        // Render list (All Companies is now included in the list from API)
        list.forEach(comp => {
            const el = document.createElement('div');
            
            // Check for "All Companies" (id = -1)
            if (comp.id === -1) {
                el.className = 'p-3 hover:bg-slate-700/50 rounded-lg cursor-pointer transition-colors border-b border-slate-800/30 flex items-center justify-between group bg-slate-800/20';
                el.innerHTML = `
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded bg-slate-600/20 flex items-center justify-center text-slate-400 group-hover:bg-slate-600 group-hover:text-white transition-colors">
                            <i class="bi bi-grid-fill"></i>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">${comp.name}</span>
                            <span class="text-[10px] text-slate-500">Filtreyi Temizle</span>
                        </div>
                    </div>
                    <i class="bi bi-arrow-counterclockwise text-slate-600 group-hover:text-white text-xs"></i>
                `;
            } else {
                el.className = 'p-3 hover:bg-slate-700/50 rounded-lg cursor-pointer transition-colors border-b border-slate-800/30 last:border-0 flex items-center justify-between group';
                el.innerHTML = `
                    <div class="flex items-center gap-3">
                        <div class="w-8 h-8 rounded bg-indigo-500/10 flex items-center justify-center text-indigo-400 group-hover:bg-indigo-500 group-hover:text-white transition-colors">
                            <i class="bi bi-building"></i>
                        </div>
                        <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">${comp.name}</span>
                    </div>
                    <i class="bi bi-chevron-right text-slate-600 group-hover:text-white text-xs"></i>
                `; 
            }

            // Pass encryptedId to selection function
            // Note: comp.encryptedId should be available from API
            // Use quotes for string argument
            el.onclick = () => selectGlobalCompany(comp.encryptedId);
            container.appendChild(el);
        });
    }

    async function selectGlobalCompany(encryptedId) {
        // Show loading overlay or simply reload page state
        const container = document.getElementById('global-company-list');
        container.innerHTML = `
            <div class="p-8 text-center space-y-3">
                <div class="animate-spin inline-block w-8 h-8 border-4 border-current border-t-transparent text-indigo-500 rounded-full"></div>
                <p class="text-sm text-slate-400">İşlem yapılıyor...</p>
            </div>
        `;

        try {
            // Pass encryptedId to ChangeCompany action (updated on server to expect string)
            const response = await fetch(`/Account/ChangeCompany?companyId=${encodeURIComponent(encryptedId)}&returnUrl=${encodeURIComponent(window.location.pathname)}`, { method: 'POST' });
            const result = await response.json();

            if (result.success) {
                // Update URL to reflect key change immediately without needing backend redirect logic for query params
                var url = new URL(window.location.href);
                // Set the parameter to the encrypted string
                url.searchParams.set("filteredCompanyId", encryptedId);
                
                // Note: Server handles cookie via Set-Cookie header. 
                // We do NOT set client-side cookie to avoid conflicts with encrypted vs raw values.
                
                window.location.href = url.toString();
            } else {
                alert(result.message || 'Hata oluştu');
                fetchGlobalCompanies(); // Restore list
            }
        } catch (error) {
            alert('Bağlantı hatası');
            fetchGlobalCompanies();
        }
    }

    // Search
    document.getElementById('global-company-search').addEventListener('input', (e) => {
        const term = e.target.value.toLowerCase();
        const filtered = globalCompanies.filter(c => c.name.toLowerCase().includes(term));
        renderGlobalCompanies(filtered);
    });
</script>
