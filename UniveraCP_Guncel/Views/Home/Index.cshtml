@{
    ViewData["Title"] = "Hoşgeldiniz";
}

<div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center p-8 rounded-2xl glass-panel max-w-2xl w-full">
        <div class="w-20 h-20 bg-indigo-500/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="bi bi-person-badge text-3xl text-indigo-400"></i>
        </div>
        
        <h1 class="text-3xl font-bold text-white mb-3">Univera Connect'e Hoşgeldiniz</h1>
        <div class="text-indigo-300 font-medium text-lg mb-6">@User.Identity?.Name</div>
        
        <p class="text-slate-400 mb-8 text-lg leading-relaxed">
            Hesabınız başarıyla oluşturuldu ve giriş yaptınız. <br />
            Ancak şu anda atanmış herhangi bir yetkiniz (rolünüz) bulunmamaktadır.
        </p>

        <div class="bg-slate-900/50 p-6 rounded-xl border border-slate-700/50 mb-8 text-left">
            <h3 class="text-white font-semibold mb-2 flex items-center gap-2">
                <i class="bi bi-info-circle text-indigo-400"></i>
                Ne Yapmalıyım?
            </h3>
            <p class="text-slate-400 text-sm">
                Sistem yöneticinizle iletişime geçerek hesabınıza uygun rollerin (Müşteri, Finans, vb.) tanımlanmasını talep ediniz. Yetkileriniz tanımlandıktan sonra ilgili ekranlara erişim sağlayabileceksiniz.
            </p>
        </div>

        <a href="/Account/Logout" class="inline-flex items-center px-6 py-3 bg-slate-800 hover:bg-slate-700 text-white rounded-xl transition-colors">
            <i class="bi bi-box-arrow-left mr-2"></i>
            Çıkış Yap
        </a>
    </div>
</div>
