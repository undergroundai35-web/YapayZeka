@model UniCP.Models.Kullanici.Account.AccountLoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr" class="h-full bg-[#0F172A]">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Giriş Yap - Univera Connect</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

    <style>
        body { font-family: 'Inter', sans-serif; }
        .glass-input {
            background: rgba(30, 41, 59, 0.7);
            border: 1px solid rgba(51, 65, 85, 0.5);
            transition: all 0.3s ease;
        }
        .glass-input:focus {
            background: rgba(30, 41, 59, 1);
            border-color: #6366F1;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1);
        }
    </style>
</head>
<body class="h-full flex text-white overflow-hidden">

    <!-- LEFT SIDE: HERO IMAGE -->
    <div class="hidden lg:flex lg:w-[55%] xl:w-[60%] relative bg-slate-900 overflow-hidden flex-col justify-center p-16 xl:p-24">
        <!-- Background Image -->
        <div class="absolute inset-0 z-0">
            <img src="/images/branding/login-bg-v5.png" class="w-full h-full object-cover object-center opacity-80" alt="Space Background">
            <!-- Overlay Gradient -->
            <div class="absolute inset-0 bg-gradient-to-t from-[#0F172A] via-[#0F172A]/40 to-transparent"></div>
            <div class="absolute inset-0 bg-indigo-900/20 mix-blend-overlay"></div>
        </div>

        <!-- Hero Content -->
        <div class="relative z-10 max-w-2xl">
            <h2 class="text-4xl xl:text-5xl font-bold text-white leading-tight mb-6">
                Empowering Your <br/>
                Business with <br/>
                <span class="text-indigo-400">Unified Solutions.</span>
            </h2>
            <p class="text-lg text-slate-300 font-light leading-relaxed max-w-lg">
                Access your entire Univera ecosystem from a single, powerful cockpit. Manage requests, analyze data, and drive growth.
            </p>
        </div>
    </div>

    <!-- RIGHT SIDE: LOGIN FORM -->
    <div class="w-full lg:w-[45%] xl:w-[40%] flex flex-col justify-center px-8 md:px-20 lg:px-24 bg-[#0F172A] relative z-20 h-full">
        
        <div class="w-full max-w-md mx-auto">
            <!-- Brand Logo -->
            <div class="mb-12 flex items-center gap-5">
                <!-- Brand Logo (SVG) -->
                <svg width="80" height="80" viewBox="0 0 100 100" class="flex-shrink-0 drop-shadow-2xl">
                    <defs>
                        <linearGradient id="bgGradientLogin" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#1e3a8a;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#3b82f6;stop-opacity:1" />
                        </linearGradient>
                        <linearGradient id="uGradientLogin" x1="0%" y1="0%" x2="0%" y2="100%">
                            <stop offset="0%" style="stop-color:#ffffff;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#cbd5e1;stop-opacity:1" />
                        </linearGradient>
                    </defs>
                    <rect x="15" y="20" width="70" height="60" rx="15" fill="url(#bgGradientLogin)" class="shadow-lg" />
                    <path d="M 38 40 V 58 A 12 12 0 0 0 62 58 V 40" fill="none" stroke="url(#uGradientLogin)" stroke-width="8" stroke-linecap="round" />
                    <circle cx="75" cy="30" r="3" fill="#60a5fa" />
                </svg>
                <div>
                    <h1 class="text-4xl font-bold tracking-tight text-white leading-none">Univera Connect</h1>
                    <p class="text-slate-400 text-sm mt-1.5 font-medium">Unified Business Portal</p>
                </div>
            </div>

            <!-- Form -->
            <form method="post" action="/Account/Login" class="space-y-6">
                @if (TempData["Mesaj"] != null)
                {
                    <div class="p-4 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-sm flex items-center gap-3">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        @TempData["Mesaj"]
                    </div>
                }

                <div class="space-y-5">
                    <!-- Hidden Project Code Input -->
                    <input type="hidden" name="projectCode" id="project-code-hidden">

                    <!-- Email -->
                    <div>
                        <label class="block text-xs font-medium text-slate-400 uppercase tracking-wider mb-2">EMAIL</label>
                        <div class="relative">
                            <i class="bi bi-person absolute left-4 top-3.5 text-slate-500"></i>
                            <input type="email" id="email" name="email" required 
                                   class="w-full pl-11 pr-4 py-3.5 rounded-xl glass-input text-sm text-white placeholder-slate-600 outline-none" 
                                   placeholder="kullanici@univera.com.tr" />
                        </div>
                    </div>

                    <!-- Password -->
                    <div>
                        <label class="block text-xs font-medium text-slate-400 uppercase tracking-wider mb-2">Password</label>
                        <div class="relative">
                            <i class="bi bi-lock absolute left-4 top-3.5 text-slate-500"></i>
                            <input type="password" id="password" name="password" required 
                                   class="w-full pl-11 pr-4 py-3.5 rounded-xl glass-input text-sm text-white placeholder-slate-600 outline-none" 
                                   placeholder="••••••••" />
                        </div>
                    </div>

                    <!-- Forgot Password Link -->
                    <div class="flex justify-end">
                        <a href="/Account/ForgotPassword" class="text-sm text-indigo-400 hover:text-indigo-300 transition-colors">
                            Şifremi Unuttum?
                        </a>
                    </div>


                </div>

                <!-- Submit Button -->
                <button type="submit" 
                        class="w-full py-3.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl shadow-lg shadow-indigo-500/25 transition-all duration-300 transform active:scale-[0.98] flex items-center justify-center gap-2 mt-4">
                    <span>Sign In</span>
                    <i class="bi bi-arrow-right"></i>
                </button>
            </form>

            <!-- Footer -->
            <div class="mt-10 text-center space-y-4">
                <p class="text-xs text-slate-500">
                    Don't have an account? 
                    <a href="#" class="text-white hover:text-indigo-400 transition-colors font-medium ml-1">Contact Support</a>
                </p>
            </div>
        </div>
    </div>

    <!-- Company Selection Modal (Moved Outside Form) -->
    <div id="company-modal" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900/90 backdrop-blur-sm hidden opacity-0 transition-opacity duration-300">
        <div class="bg-[#1E293B] border border-slate-700 rounded-2xl shadow-2xl w-full max-w-lg mx-4 overflow-hidden transform scale-95 transition-transform duration-300" id="company-modal-content">
            <!-- Header -->
            <div class="p-6 border-b border-slate-700/50 flex justify-between items-center bg-slate-800/50">
                <h3 class="text-lg font-semibold text-white">Firma Seçimi</h3>
                <button type="button" id="close-modal" class="text-slate-400 hover:text-white transition-colors">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
            
            <!-- Company Search and List -->
            <div class="p-4 border-b border-slate-700/50 bg-[#0F172A]/50">
                <div class="relative">
                    <i class="bi bi-search absolute left-4 top-3.5 text-slate-500"></i>
                    <input type="text" id="company-search" placeholder="Firma Ara..." 
                           class="w-full pl-11 pr-4 py-3 rounded-xl bg-slate-800 border border-slate-700 text-sm text-white focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition-all">
                </div>
            </div>

            <div class="max-h-[300px] overflow-y-auto p-2" id="company-list-container">
                <div class="p-4 text-center text-slate-500 text-sm hidden" id="modal-no-results">Sonuç bulunamadı</div>
            </div>

            <div class="p-4 border-t border-slate-700/50 bg-slate-800/50 flex justify-end gap-3">
                <button type="button" id="cancel-selection" 
                        class="px-4 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-white hover:bg-slate-700 transition-colors">
                    İptal
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loginForm = document.querySelector('form');
            const emailInput = document.getElementById('email');
            const passwordInput = document.getElementById('password');
            const hiddenProjectCode = document.getElementById('project-code-hidden');
            
            const modal = document.getElementById('company-modal');
            const modalContent = document.getElementById('company-modal-content');
            const companyListContainer = document.getElementById('company-list-container');
            const companySearch = document.getElementById('company-search');
            const closeModalBtn = document.getElementById('close-modal');
            const cancelBtn = document.getElementById('cancel-selection');
            
            let companies = [];
            let isAuthenticating = false;

            // Submit Handler
            loginForm.addEventListener('submit', async function(e) {
                if (loginForm.getAttribute('data-submitting') === 'true') return;

                e.preventDefault();
                
                if (isAuthenticating) return;
                isAuthenticating = true;

                const submitBtn = loginForm.querySelector('button[type="submit"]');
                const originalBtnText = submitBtn.innerHTML;
                
                // Loading State
                submitBtn.innerHTML = '<span class="animate-spin inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full mr-2"></span> Checking...';
                submitBtn.disabled = true;

                try {
                    const response = await fetch('/Account/PreLoginCheck', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            email: emailInput.value,
                            password: passwordInput.value
                        })
                    });

                    if (!response.ok) {
                         throw new Error('Network response was not ok: ' + response.statusText);
                    }

                    const result = await response.json();

                    if (!result.success) {
                        alert(result.message || 'Giriş hatası');
                        resetButton();
                        return;
                    }

                    if ((result.type === 1 || result.type === 4) && !result.forceChange) {
                        // Admin/Internal/Univera Customer -> Show Company Modal ONLY if no force change required
                        companies = result.projects || [];
                        renderCompanies(companies);
                        openModal();
                        resetButton(); // Reset button so they can see the modal
                    } else {
                        // Customer OR Force Change -> Submit directly
                        loginForm.setAttribute('data-submitting', 'true');
                        loginForm.submit();
                    }

                } catch (error) {
                    console.error('Login error:', error);
                    alert('Bir hata oluştu: ' + error.message);
                    resetButton();
                }

                function resetButton() {
                    submitBtn.innerHTML = originalBtnText;
                    submitBtn.disabled = false;
                    isAuthenticating = false;
                }
            });

            // Modal Logic
            function openModal() {
                modal.classList.remove('hidden');
                // Small delay to allow display flow
                requestAnimationFrame(() => {
                    modal.classList.remove('opacity-0');
                    modalContent.classList.remove('scale-95');
                    modalContent.classList.add('scale-100');
                    companySearch.focus();
                });
            }

            function closeModal() {
                modal.classList.add('opacity-0');
                modalContent.classList.remove('scale-100');
                modalContent.classList.add('scale-95');
                setTimeout(() => {
                    modal.classList.add('hidden');
                }, 300);
            }

            if(closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
            if(cancelBtn) cancelBtn.addEventListener('click', closeModal);

            function renderCompanies(list) {
                companyListContainer.innerHTML = '';
                const noResults = document.getElementById('modal-no-results');
                
                if(!list || list.length === 0) {
                     if(noResults) noResults.classList.remove('hidden');
                     return;
                }
                if(noResults) noResults.classList.add('hidden');

                list.forEach(comp => {
                    const el = document.createElement('div');
                    el.className = 'p-3 hover:bg-slate-700/50 rounded-lg cursor-pointer transition-colors border-b border-slate-800/30 last:border-0 flex items-center justify-between group';
                    el.innerHTML = `
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded bg-indigo-500/10 flex items-center justify-center text-indigo-400 group-hover:bg-indigo-500 group-hover:text-white transition-colors">
                                <i class="bi bi-building"></i>
                            </div>
                            <span class="text-sm font-medium text-slate-300 group-hover:text-white transition-colors">${comp.name}</span>
                        </div>
                        <i class="bi bi-chevron-right text-slate-600 group-hover:text-white text-xs"></i>
                    `;
                    el.onclick = () => selectCompany(comp.id);
                    companyListContainer.appendChild(el);
                });
            }

            function selectCompany(id) {
                hiddenProjectCode.value = id;
                loginForm.setAttribute('data-submitting', 'true');
                loginForm.submit();
                closeModal();
            }

            if(companySearch) {
                companySearch.addEventListener('input', (e) => {
                    const term = e.target.value.toLowerCase();
                    const filtered = companies.filter(c => c.name.toLowerCase().includes(term));
                    renderCompanies(filtered);
                });
            }
        });
    </script>
</body>
</html>
