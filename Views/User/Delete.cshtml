@model UniCP.Models.Kullanici.AppUser

@{
    ViewData["Title"] = "Kullanıcı Sil";
}

<div class="max-w-2xl mx-auto py-10">
    <div class="bg-slate-800 rounded-2xl border border-slate-700 p-8 shadow-xl">
        <div class="text-center mb-8">
            <div class="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="bi bi-exclamation-triangle text-3xl text-red-500"></i>
            </div>
            <h1 class="text-2xl font-bold text-white mb-2">Kullanıcıyı Sil</h1>
            <p class="text-slate-400">
                <span class="text-white font-semibold">@Model.AdSoyad</span> (@Model.Email) isimli kullanıcıyı silmek istediğinize emin misiniz?
            </p>
            <p class="text-red-400 text-sm mt-2">Bu işlem geri alınamaz!</p>
        </div>

        <form asp-action="DeleteConfirm" method="post" class="flex items-center justify-center gap-4">
            <input type="hidden" asp-for="Id" />
            
            <a asp-action="Index" class="px-6 py-2.5 rounded-xl border border-slate-600 text-slate-300 hover:bg-slate-700 hover:text-white transition-colors">
                İptal
            </a>
            
            <button type="submit" class="px-6 py-2.5 rounded-xl bg-red-600 hover:bg-red-700 text-white font-medium shadow-lg shadow-red-500/20 transition-colors flex items-center gap-2">
                <i class="bi bi-trash"></i>
                <span>Evet, Sil</span>
            </button>
        </form>
    </div>
</div>
