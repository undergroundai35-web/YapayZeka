@{
    ViewData["Title"] = "AI Token Yükle";
    Layout = "~/Views/Shared/_LayoutMusteri.cshtml";
    decimal currentBalance = ViewBag.CurrentBalance ?? 0;
}

<div class="container mx-auto px-4 py-8">
    
    <!-- Balance Header -->
    <div class="bg-gradient-to-r from-indigo-600 to-violet-600 rounded-3xl p-8 mb-12 text-white shadow-xl relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-white opacity-5 rounded-full -mr-20 -mt-20"></div>
        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-bold mb-2">AI Token Bakiyeniz</h1>
                <p class="text-indigo-100 opacity-90">Univera Asistan ile daha fazla işlem yapmak için bakiyenizi artırın.</p>
            </div>
            <div class="text-center md:text-right bg-white/10 rounded-2xl p-4 backdrop-blur-sm border border-white/20">
                <div class="text-sm text-indigo-100 mb-1">Mevcut Bakiye</div>
                <div class="text-4xl font-mono font-bold" id="headerBalance">@currentBalance.ToString("N0")</div>
                <div class="text-xs text-indigo-200 mt-1">Token</div>
            </div>
        </div>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        
        <!-- Starter Package -->
        <div class="bg-slate-800 rounded-3xl p-8 border border-slate-700 hover:border-indigo-500/50 transition-all duration-300 group hover:-translate-y-1 relative">
            <div class="text-lg font-semibold text-slate-400 mb-4">Başlangıç Paketi</div>
            <div class="flex items-baseline gap-1 mb-6">
                <span class="text-4xl font-bold text-white">Ücretsiz</span>
                <span class="text-slate-500">/ demo</span>
            </div>
            <div class="bg-slate-700/50 rounded-2xl p-4 mb-8 text-center">
                <span class="text-3xl font-bold text-indigo-400">1.000</span>
                <span class="text-sm text-slate-400 block mt-1">Token</span>
            </div>
            <ul class="space-y-4 mb-8 text-slate-300 text-sm">
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-emerald-500"></i> Yaklaşık 20 soru-cevap</li>
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-emerald-500"></i> Temel analizler</li>
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-emerald-500"></i> 7/24 Erişim</li>
            </ul>
            <button onclick="purchaseTokens(1000)" class="w-full py-4 rounded-xl bg-slate-700 text-white font-semibold hover:bg-slate-600 transition-colors">
                Yükle
            </button>
        </div>

        <!-- Pro Package -->
        <div class="bg-slate-900 rounded-3xl p-8 border-2 border-indigo-500 shadow-2xl shadow-indigo-500/10 transform scale-105 relative">
            <div class="absolute top-0 right-0 bg-indigo-500 text-white text-xs font-bold px-3 py-1 rounded-bl-xl rounded-tr-2xl">ÖNERİLEN</div>
            <div class="text-lg font-semibold text-indigo-400 mb-4">Pro Paket</div>
            <div class="flex items-baseline gap-1 mb-6">
                <span class="text-4xl font-bold text-white">Ücretsiz</span>
                <span class="text-slate-500">/ demo</span>
            </div>
            <div class="bg-indigo-500/10 rounded-2xl p-4 mb-8 text-center border border-indigo-500/20">
                <span class="text-3xl font-bold text-indigo-400">5.000</span>
                <span class="text-sm text-slate-400 block mt-1">Token</span>
            </div>
            <ul class="space-y-4 mb-8 text-slate-300 text-sm">
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-indigo-500"></i> Yaklaşık 100 soru-cevap</li>
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-indigo-500"></i> Detaylı rapor analizleri</li>
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-indigo-500"></i> Öncelikli işlem</li>
            </ul>
            <button onclick="purchaseTokens(5000)" class="w-full py-4 rounded-xl bg-indigo-600 text-white font-semibold hover:bg-indigo-700 shadow-lg shadow-indigo-600/20 transition-all hover:shadow-indigo-600/40">
                Hemen Yükle
            </button>
        </div>

        <!-- Enterprise Package -->
        <div class="bg-slate-800 rounded-3xl p-8 border border-slate-700 hover:border-violet-500/50 transition-all duration-300 group hover:-translate-y-1">
            <div class="text-lg font-semibold text-violet-400 mb-4">Kurumsal Paket</div>
            <div class="flex items-baseline gap-1 mb-6">
                <span class="text-4xl font-bold text-white">Ücretsiz</span>
                <span class="text-slate-500">/ demo</span>
            </div>
            <div class="bg-slate-700/50 rounded-2xl p-4 mb-8 text-center">
                <span class="text-3xl font-bold text-violet-400">10.000</span>
                <span class="text-sm text-slate-400 block mt-1">Token</span>
            </div>
            <ul class="space-y-4 mb-8 text-slate-300 text-sm">
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-violet-500"></i> Sınırsız analiz</li>
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-violet-500"></i> PDF/Excel Entegrasyonu</li>
                <li class="flex items-center gap-3"><i class="bi bi-check-circle-fill text-violet-500"></i> Maksimum Bağlam</li>
            </ul>
            <button onclick="purchaseTokens(10000)" class="w-full py-4 rounded-xl bg-slate-700 text-white font-semibold hover:bg-violet-600 transition-colors">
                Yükle
            </button>
        </div>

    <!-- Admin Generator Section -->
    <div class="mt-16 bg-slate-900 rounded-3xl p-1 border border-slate-800">
        <div class="bg-gradient-to-r from-slate-900 to-slate-800 rounded-[22px] p-8">
            <div class="flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="flex-1">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                        <h2 class="text-xl font-mono font-bold text-emerald-400">ADMIN KONSOLU</h2>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2">Özel Token Üretimi</h3>
                    <p class="text-slate-400 text-sm">Sistem yöneticisi olarak dilediğiniz miktarda token oluşturup bakiyenize ekleyebilirsiniz.</p>
                </div>
                
                <div class="flex-1 w-full max-w-md bg-black/30 rounded-xl p-2 border border-slate-700/50 flex gap-2">
                    <input type="number" id="customAmount" placeholder="Miktar (örn: 50000)" class="bg-transparent border-none text-white placeholder-slate-600 focus:ring-0 w-full font-mono text-lg" />
                    <button onclick="generateCustomTokens()" class="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-3 rounded-lg font-bold transition-all shadow-lg shadow-emerald-900/20 whitespace-nowrap">
                        <i class="bi bi-cpu-fill mr-2"></i> Üret
                    </button>
                </div>
            </div>
            
            <!-- Terminal Output -->
            <div id="consoleOutput" class="hidden mt-6 bg-black rounded-lg p-4 font-mono text-xs md:text-sm h-32 overflow-y-auto border border-slate-800 text-emerald-500/80">
            </div>
        </div>
    </div>
</div>

<script>
    function log(msg) {
        const consoleEl = document.getElementById('consoleOutput');
        consoleEl.classList.remove('hidden');
        const time = new Date().toLocaleTimeString();
        consoleEl.innerHTML += `<div><span class="text-slate-500">[${time}]</span> ${msg}</div>`;
        consoleEl.scrollTop = consoleEl.scrollHeight;
    }

    function generateCustomTokens() {
        const amountInput = document.getElementById('customAmount');
        const amount = parseInt(amountInput.value);

        if (!amount || amount <= 0) {
            alert("Lütfen geçerli bir miktar girin.");
            return;
        }

        const btn = event.currentTarget;
        btn.disabled = true;
        btn.classList.add('opacity-50');

        log(`Sistem başlatılıyor...`);
        log(`Hedef bakiye artışı: +${new Intl.NumberFormat('en-US').format(amount)}`);

        // Simulate processing visuals
        setTimeout(() => {
            log(`Blok zinciri simülasyonu çalışıyor...`);
            
            fetch('/Finans/PurchaseTokens', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `amount=${amount}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    log(`İŞLEM BAŞARILI: ${data.message}`);
                    log(`Yeni Bakiye: ${new Intl.NumberFormat('en-US').format(data.newBalance)}`);
                    
                    document.getElementById('headerBalance').innerText = new Intl.NumberFormat('tr-TR').format(data.newBalance);
                    amountInput.value = '';
                } else {
                    log(`HATA: ${data.message}`);
                }
            })
            .finally(() => {
                btn.disabled = false;
                btn.classList.remove('opacity-50');
            });

        }, 800);
    }
    
    function purchaseTokens(amount) {
        // Show loading state (optional)
        const btn = event.currentTarget;
        const originalText = btn.innerText;
        btn.innerText = "Yükleniyor...";
        btn.disabled = true;

        fetch('/Finans/PurchaseTokens', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/x-www-form-urlencoded',
            },
            body: `amount=${amount}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                // Update header balance
                document.getElementById('headerBalance').innerText = new Intl.NumberFormat('tr-TR').format(data.newBalance);
                
                // Show success toast/alert
                // Simple Alert for now
                alert(data.message);
            } else {
                alert('Hata: ' + data.message);
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('Bir hata oluştu.');
        })
        .finally(() => {
             btn.innerText = "Yükle"; // Reset text (though usually we'd keep it as purchased or disable)
             btn.innerText = "Yüklendi!";
             setTimeout(() => {
                 btn.innerText = originalText;
                 btn.disabled = false;
             }, 2000);
        });
    }
</script>
